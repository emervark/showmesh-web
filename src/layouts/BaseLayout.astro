---
import '../styles/global.css';
const {
  title = 'Showmesh — Realtime show automation for Windows',
  description = 'Showmesh is a Windows-first realtime show automation application for theatres, concerts, immersive installations and live events.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
