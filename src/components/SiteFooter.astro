---
const product = [
  { href: '#model', label: 'Product' },
  { href: '#model', label: 'How it works' },
  { href: '#operator', label: 'Live operation' },
  { href: '#integrations', label: 'Integrations' },
  { href: 'https://manual.showmesh.app', label: 'Manual' },
  { href: '#access', label: 'Development' }
];
const company = [
  { href: 'mailto:info@showmesh.app', label: 'info@showmesh.app' },
  { href: 'mailto:support@showmesh.app', label: 'support@showmesh.app' },
  { href: '#access', label: 'Request early access' },
  { href: '/showmesh-ui.html', label: 'Operator UI concept' }
];
---

<footer class="site-footer">
  <div class="site-footer__cols">
    <div class="site-footer__about">
      <img
        class="site-footer__logo"
        src="/showmesh-logo-stacked.svg"
        alt="Showmesh"
        width="150"
        height="105"
      />
      <p>
        Showmesh is a Windows-first realtime show automation system for media,
        realtime graphics and control.
      </p>
      <p class="site-footer__maker">
        Developed by <strong>VFX OÜ</strong>.
      </p>
    </div>
    <div class="site-footer__group">
      <div class="site-footer__label">Product</div>
      <div class="site-footer__links">
        {product.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
    <div class="site-footer__group">
      <div class="site-footer__label">Company</div>
      <div class="site-footer__links">
        {company.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
  <div class="site-footer__base">
    © 2026 Showmesh — a VFX OÜ product. Connect, automate and run the show.
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--sm-border);
    padding: 56px 24px 34px;
  }
  .site-footer__cols {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
  }
  .site-footer__logo {
    height: 84px;
    width: auto;
    display: block;
    margin-bottom: 16px;
  }
  .site-footer__about p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--sm-text-faint);
    max-width: 280px;
    margin: 0;
  }
  .site-footer__maker {
    margin-top: 12px !important;
  }
  .site-footer__maker strong {
    color: var(--sm-text-secondary);
    font-weight: 650;
  }
  .site-footer__label {
    font-size: 11.5px;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #4e555f;
    margin-bottom: 14px;
  }
  .site-footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .site-footer__links a {
    font-size: 13.5px;
    color: var(--sm-text-muted);
    transition: color 160ms ease;
  }
  .site-footer__links a:hover {
    color: var(--sm-text-strong);
  }
  .site-footer__base {
    max-width: 1180px;
    margin: 40px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--sm-border);
    font-size: 12px;
    color: #3f454e;
  }
</style>
