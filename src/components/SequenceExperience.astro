---
const sequence = [
  ['01', 'Connect', 'top'],
  ['02', 'Automate', 'build'],
  ['03', 'Run', 'run'],
  ['04', 'See what is live', 'live'],
  ['05', 'Control what happens next', 'systems'],
  ['06', 'Early access', 'contact']
];
---

<div class="sequence-experience" data-sequence-root data-scene="0">
  <div class="visual-field" aria-hidden="true">
    <canvas data-visual-field></canvas>
    <span class="visual-field-status">PROGRAM / GENERATIVE FIELD</span>
  </div>
  <aside class="sequence-rail" aria-label="Page sequence">
    <span class="rail-title">SHOW SEQUENCE</span>
    <ol>
      {
        sequence.map(([number, label, id], index) => (
          <li>
            <a
              href={`#${id}`}
              aria-current={index === 0 ? 'step' : undefined}
              data-rail-cue={index}
            >
              <>
                <span>{number}</span>
                <b>{label}</b>
              </>
            </a>
          </li>
        ))
      }
    </ol>
    <span class="rail-status"><i></i> SHOW READY</span>
  </aside>

  <div class="sequence-content">
    <section
      id="top"
      class="sequence-section hero"
      data-sequence-section
      data-stage="0"
    >
      <div class="hero-copy">
        <span class="kicker">Realtime show automation for Windows</span>
        <h1>Everything that makes the show. One sequence that runs it.</h1>
        <p>
          Build and operate media, realtime graphics, control signals, and
          external systems from one Windows-native workspace.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href="#build">Build the next cue</a>
          <a class="btn" href="/showmesh-ui.html" target="_blank"
            >Open the full operator UI <span aria-hidden="true">↗</span></a
          >
        </div>
      </div>

      <div
        class="run-console"
        tabindex="0"
        aria-label="Interactive current and next cue demonstration. Press the GO button to advance."
      >
        <div class="console-mode">
          <span><i></i> SHOW MODE</span><span>PROGRAM · 1080p60</span>
        </div>
        <div class="now-block">
          <span class="state-label">NOW · PLAYING</span>
          <div class="cue-identity">
            <b data-now-number>07</b>
            <strong data-now-name>aseri_movie_v1.mov</strong>
            <time data-now-time>01:24.0 / 02:15.6</time>
          </div>
          <div class="progress-track" aria-hidden="true">
            <span data-progress></span>
          </div>
          <div class="action-chain" aria-label="Actions on the playing cue">
            <span class="action done"><i></i> Fade in · done</span>
            <span class="action running"><i></i> Blur 0 → 20</span>
            <span class="action live"><i></i> OSC /smoke/fog · 0.64</span>
          </div>
        </div>
        <div class="next-block">
          <span class="state-label">NEXT</span>
          <div class="cue-identity">
            <b data-next-number>08</b>
            <strong data-next-name>Smoke Field</strong>
            <small data-next-intent>Fog 0 → 0.8 · ON PLAY</small>
          </div>
        </div>
        <div class="go-row">
          <button type="button" class="go-button" data-hero-go>
            <span>GO</span><small data-go-target>Run cue 08</small>
          </button>
          <span class="go-hint">Click GO to advance the live state</span>
        </div>
      </div>
    </section>

    <section
      id="build"
      class="sequence-section build-section"
      data-sequence-section
      data-stage="1"
    >
      <header class="section-intro">
        <span class="cue-index">02 · AUTOMATE</span>
        <h2>Build outcomes, not workarounds.</h2>
        <p>
          Choose what you control, define what changes, then decide when it
          happens.
        </p>
      </header>

      <div class="build-demo" data-build-demo>
        <div class="build-preview" aria-label="Fog density preview">
          <div class="fog-field" data-fog-field>
            <span></span><span></span><span></span>
          </div>
          <div class="preview-readout">
            <span>PROGRAM · L2</span><b
              >FOG <output data-fog-output>0.00</output></b
            >
          </div>
        </div>

        <div class="flow-editor">
          <div class="flow-stage resource-stage">
            <span class="flow-label">RESOURCE</span>
            <div
              class="resource-list"
              role="group"
              aria-label="Choose resource"
            >
              <button
                type="button"
                class="is-selected"
                aria-pressed="true"
                data-resource="Smoke_Field.nblock"
                data-parameter="Fog density"
                data-target="0.8">◈ Smoke_Field.nblock</button
              >
              <button
                type="button"
                aria-pressed="false"
                data-resource="aseri_movie_v1.mov"
                data-parameter="Opacity"
                data-target="1.0">▶ aseri_movie_v1.mov</button
              >
              <button
                type="button"
                aria-pressed="false"
                data-resource="Program"
                data-parameter="Master level"
                data-target="0.7">▣ Program output</button
              >
            </div>
          </div>

          <div class="flow-link" aria-hidden="true"><i></i></div>

          <div class="flow-stage action-stage">
            <span class="flow-label">ACTION</span>
            <div class="action-value">
              <span data-action-name>Fog density</span>
              <b><i>0.0</i><em>→</em><output data-action-target>0.8</output></b>
              <small>4.000 s</small>
            </div>
          </div>

          <div class="flow-link" aria-hidden="true"><i></i></div>

          <div class="flow-stage trigger-stage">
            <span class="flow-label">TRIGGER</span>
            <div
              class="trigger-options"
              role="group"
              aria-label="Choose trigger"
            >
              <button
                type="button"
                class="is-selected"
                aria-pressed="true"
                data-trigger="ON PLAY">ON PLAY</button
              >
              <button
                type="button"
                aria-pressed="false"
                data-trigger="OSC /smoke/fog">OSC /smoke/fog</button
              >
            </div>
          </div>

          <button type="button" class="mini-go" data-build-go>
            <span>GO</span><small>Run this cue</small>
          </button>
        </div>

        <div class="flow-summary" aria-live="polite">
          <i></i><span data-flow-summary
            >Smoke_Field.nblock → Fog density 0.0 → 0.8 → ON PLAY</span
          >
        </div>
      </div>
    </section>

    <section
      id="run"
      class="sequence-section run-section"
      data-sequence-section
      data-stage="2"
    >
      <header class="section-intro narrow">
        <span class="cue-index">03 · RUN</span>
        <h2>The operator should never have to guess.</h2>
        <p>
          Current cue, remaining time, the next action, and system health stay
          visible throughout the show.
        </p>
      </header>

      <div class="operator-strip">
        <div class="operator-now">
          <span>PLAYING</span><b>07</b><strong>aseri_movie_v1.mov</strong>
          <div class="time-pair">
            <time>01:24.0</time><small>−00:51.6</small>
          </div>
          <i aria-hidden="true"></i>
        </div>
        <div class="operator-next">
          <span>NEXT</span><b>08</b><strong>Smoke Field</strong>
          <small>Starts block · Fog 0 → 0.8 · holds until stopped</small>
        </div>
        <button type="button" class="operator-go" data-run-go
          ><span>GO</span><small>CUE 08</small></button
        >
      </div>

      <div class="cue-context">
        <div class="cue-list-fragment">
          <div class="cue-row playing">
            <span class="rail"></span><b>07</b>
            <div>
              <strong>aseri_movie_v1.mov</strong><small>Program · 02:15.6</small
              >
            </div>
            <em>PLAYING</em>
          </div>
          <div class="attached-actions">
            <div>
              <i class="done"></i><span>07.1 · Fade in</span><b>done</b>
            </div>
            <div>
              <i class="running"></i><span>07.2 · Blur</span><b>0 → 20</b>
            </div>
            <div>
              <i class="live"></i><span>07.3 · Fog density</span><b
                >OSC · 0.64</b
              >
            </div>
          </div>
          <div class="cue-row next">
            <span class="rail"></span><b>08</b>
            <div>
              <strong>Smoke Field</strong><small>Program · L2 · hold</small>
            </div>
            <em>NEXT</em>
          </div>
          <div class="cue-row warning">
            <span class="rail"></span><b>10</b>
            <div>
              <strong>Dim to blackout</strong><small
                >Action target cue not found</small
              >
            </div>
            <em>WARNING</em>
          </div>
        </div>

        <aside class="inspector-fragment">
          <div class="inspector-title">
            <span>CUE INSPECTOR</span><b data-run-inspector-title
              >08 · Smoke Field</b
            ><small data-run-inspector-state>▶ NEXT</small>
          </div>
          <dl>
            <div>
              <dt>RESOURCE</dt><dd data-run-resource>Smoke_Field.nblock</dd>
            </div>
            <div><dt>DURATION</dt><dd data-run-duration>hold</dd></div>
            <div><dt>OUTPUT</dt><dd data-run-output>Program · L2</dd></div>
            <div><dt>ACTIONS</dt><dd data-run-actions>3 · triggers</dd></div>
            <div class="live-field">
              <dt data-run-live-label>FOG DENSITY</dt><dd data-run-live-value>
                0.64 · OSC live
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section
      id="live"
      class="sequence-section live-section"
      data-sequence-section
      data-stage="3"
    >
      <header class="section-intro">
        <span class="cue-index">04 · SEE WHAT IS LIVE</span>
        <h2>Live input belongs inside the cue.</h2>
        <p>
          Let timecode, OSC, MIDI, and realtime data shape the sequence while it
          runs.
        </p>
      </header>

      <div class="live-console" data-live-console>
        <div class="live-inputs">
          <span class="panel-label">LIVE INPUTS</span>
          <div class="input-row active">
            <span><i></i> OSC</span><b>/smoke/fog</b><output data-osc-value
              >0.64</output
            >
          </div>
          <label class="value-slider">
            <span>Fog density</span>
            <input
              type="range"
              min="0"
              max="100"
              value="64"
              aria-label="OSC fog density"
              data-osc-slider
            />
          </label>
          <button type="button" class="input-row" data-midi-pulse>
            <span><i></i> MIDI</span><b>Console · CC 21</b><output
              data-midi-value>92</output
            >
          </button>
          <div class="input-row">
            <span><i></i> TIMECODE</span><b>LTC · 25 fps</b><output
              data-timecode-output>01:12:08:14</output
            >
          </div>
        </div>

        <div class="parameter-monitor">
          <div class="monitor-head">
            <span>SMOKE FIELD · PARAMETERS</span><b><i></i> LIVE</b>
          </div>
          <div class="parameter-visual" data-live-fog>
            <span class="fog-a"></span><span class="fog-b"></span><span
              class="fog-c"></span>
            <strong>FOG</strong><output data-live-output>0.64</output>
          </div>
          <div class="meter-list">
            <div>
              <span>Fog density</span><i><b data-fog-meter></b></i><output
                data-live-meter>64%</output
              >
            </div>
            <div class="meter-control">
              <span>Bloom</span><i><b data-bloom-meter style="width:48%"></b></i
              ><output data-bloom-output>1.20</output>
              <input
                type="range"
                min="0"
                max="100"
                value="48"
                aria-label="Bloom"
                data-bloom-slider
              />
            </div>
            <div class="meter-control">
              <span>Particle count</span><i
                ><b data-particle-meter style="width:66%"></b></i
              ><output data-particle-output>800k</output>
              <input
                type="range"
                min="10"
                max="100"
                value="66"
                aria-label="Particle count"
                data-particle-slider
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="systems"
      class="sequence-section systems-section"
      data-sequence-section
      data-stage="4"
    >
      <header class="section-intro narrow">
        <span class="cue-index">05 · CONTROL WHAT HAPPENS NEXT</span>
        <h2>The interface edits the show. The engine runs it.</h2>
        <p>
          Playback, rendering, output, and live control remain visible as one
          operating system without competing for the operator's attention.
        </p>
      </header>

      <div class="systems-map" aria-label="Showmesh connected systems">
        <div class="system-node media" tabindex="0" data-route="0,3">
          <span>MEDIA</span><b>Video + audio</b><small>Core</small>
        </div>
        <div class="system-node control">
          <span>CONTROL</span><b>OSC + MIDI</b><small>Planned</small>
        </div>
        <div class="system-node realtime" tabindex="0" data-route="2,3">
          <span>REALTIME</span><b>Notch Blocks</b><small>Exploratory</small>
        </div>
        <div class="system-node output" tabindex="0" data-route="3">
          <span>OUTPUT</span><b>Program</b><small>Core</small>
        </div>
        <div class="system-core">
          <span>SHOWMESH CUE</span><b>08 · Smoke Field</b><small
            >3 actions · hold</small
          >
          <i></i>
        </div>
        <svg
          viewBox="0 0 1000 420"
          aria-hidden="true"
          preserveAspectRatio="none"
        >
          <path data-route-path="0" d="M210 90 C360 90 350 210 500 210"></path>
          <path d="M790 90 C640 90 650 210 500 210"></path>
          <path data-route-path="2" d="M210 330 C360 330 350 210 500 210"
          ></path>
          <path data-route-path="3" d="M500 210 C650 210 640 330 790 330"
          ></path>
        </svg>
      </div>

      <div class="telemetry-bar" aria-label="System telemetry">
        <div><span>PROGRAM</span><b>1080p60</b><small>OUTPUT READY</small></div>
        <div><span>ENGINE</span><b>93 FPS</b><small>FRAME 10.7 MS</small></div>
        <div><span>AUDIO</span><b>48 kHz</b><small>512 SMP</small></div>
        <div class="telemetry-live">
          <span>OSC</span><b>LIVE</b><small>/smoke/fog</small>
        </div>
      </div>
    </section>

    <section
      id="contact"
      class="sequence-section final-go"
      data-sequence-section
      data-stage="5"
    >
      <div class="final-next">
        <span>NEXT</span><b>12</b>
        <div>
          <strong>Build your first show</strong><small
            >Showmesh early access</small
          >
        </div>
        <button class="final-go-button" type="button" data-final-go>
          <span>GO</span><small>Request early access</small>
        </button>
      </div>
      <p>
        Showmesh is in early development. Tell us about the systems, rooms, and
        cues you need to run.
      </p>
      <form
        class="access-inspector"
        data-access-inspector
        hidden
        inert
        action="mailto:hello@showmesh.app"
        method="post"
        enctype="text/plain"
      >
        <header>
          <span>CUE INSPECTOR</span><b>12 · EARLY ACCESS</b><small>READY</small>
        </header>
        <label
          ><span>NAME</span><input
            name="name"
            autocomplete="name"
            required
          /></label
        >
        <label
          ><span>EMAIL</span><input
            type="email"
            name="email"
            autocomplete="email"
            required
          /></label
        >
        <label
          ><span>SHOW / SYSTEMS</span><textarea
            name="systems"
            rows="3"
            placeholder="Theatre, concert, installation…"></textarea></label
        >
        <button class="btn primary" type="submit">SEND REQUEST</button>
      </form>
    </section>
  </div>
</div>

<script>
  const cueStates = [
    {
      number: '07',
      name: 'aseri_movie_v1.mov',
      time: '01:24.0 / 02:15.6',
      intent: 'Fog 0 → 0.8 · ON PLAY'
    },
    {
      number: '08',
      name: 'Smoke Field',
      time: '00:00.0 / hold',
      intent: 'Crossfade from cue 07 · 2.0 s'
    },
    {
      number: '09',
      name: 'Leaves_Cold_Snowflakes',
      time: '00:00.0 / 03:10.0',
      intent: 'Dim to blackout · 4.0 s'
    },
    {
      number: '10',
      name: 'Dim to blackout',
      time: '00:00.0 / 00:04.0',
      intent: 'Finale · fires together'
    },
    {
      number: '11',
      name: 'Finale',
      time: '00:00.0 / auto',
      intent: 'Build your first show'
    }
  ] as const;

  document
    .querySelectorAll<HTMLElement>('[data-sequence-root]')
    .forEach((root) => {
      root.classList.add('is-choreographed');
      const railLinks = Array.from(
        root.querySelectorAll<HTMLElement>('[data-rail-cue]')
      );
      const sections = Array.from(
        root.querySelectorAll<HTMLElement>('[data-sequence-section]')
      );
      const reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;
      const canvas = root.querySelector<HTMLCanvasElement>(
        '[data-visual-field]'
      );
      const ctx = canvas?.getContext('2d', { alpha: false });
      const feedbackCanvas = document.createElement('canvas');
      const feedbackCtx = feedbackCanvas.getContext('2d');
      const channelCanvas = document.createElement('canvas');
      const channelCtx = channelCanvas.getContext('2d');
      const sceneLooks = [
        { fog: 0.28, bloom: 0.28, energy: 0.32, split: 0.15 },
        { fog: 0.46, bloom: 0.4, energy: 0.42, split: 0.08 },
        { fog: 0.34, bloom: 0.56, energy: 0.7, split: 0.22 },
        { fog: 0.64, bloom: 0.68, energy: 0.58, split: 0.14 },
        { fog: 0.3, bloom: 0.42, energy: 0.82, split: 0.28 },
        { fog: 0.08, bloom: 0.12, energy: 0.08, split: 0 }
      ];
      let look = { ...sceneLooks[0] };
      let targetLook = { ...look };
      let visualTime = 0;

      const resizeField = () => {
        if (!canvas) return;
        const ratio = Math.min(devicePixelRatio, 1.5);
        const width = canvas.clientWidth || innerWidth;
        const height = canvas.clientHeight || innerHeight;
        canvas.width = Math.max(1, Math.floor(width * ratio));
        canvas.height = Math.max(1, Math.floor(height * ratio));
        feedbackCanvas.width = channelCanvas.width = canvas.width;
        feedbackCanvas.height = channelCanvas.height = canvas.height;
      };
      const drawField = () => {
        if (!canvas || !ctx) return;
        const w = canvas.width,
          h = canvas.height;
        Object.keys(look).forEach((key) => {
          const k = key as keyof typeof look;
          look[k] += (targetLook[k] - look[k]) * (reduced ? 1 : 0.025);
        });
        if (feedbackCtx) {
          feedbackCtx.globalCompositeOperation = 'copy';
          feedbackCtx.drawImage(canvas, 0, 0);
        }
        ctx.globalCompositeOperation = 'source-over';
        ctx.fillStyle = reduced ? '#0b0e12' : 'rgba(7,9,12,.13)';
        ctx.fillRect(0, 0, w, h);
        const t = reduced ? 7 : visualTime;
        if (!reduced && feedbackCtx) {
          const sliceHeight = Math.max(10, Math.round(h / 46));
          ctx.save();
          ctx.globalAlpha = 0.36 + look.fog * 0.12;
          for (let y = 0; y < h; y += sliceHeight) {
            const displacement =
              Math.sin(y * 0.012 + t * 0.19) * (1.5 + look.fog * 7);
            ctx.drawImage(
              feedbackCanvas,
              0,
              y,
              w,
              sliceHeight,
              displacement,
              y + Math.cos(y * 0.009 + t * 0.11),
              w,
              sliceHeight
            );
          }
          ctx.restore();
        }
        for (let i = 0; i < 8; i++) {
          const phase = t * (0.07 + i * 0.006) + i * 2.17;
          const x = w * (0.5 + Math.sin(phase * 1.13) * 0.38);
          const y = h * (0.5 + Math.cos(phase * 0.83) * 0.4);
          const radius =
            Math.min(w, h) * (0.16 + look.fog * 0.28 + (i % 3) * 0.025);
          const grad = ctx.createRadialGradient(x, y, 0, x, y, radius);
          const coral = i % 4 === 0;
          grad.addColorStop(
            0,
            coral
              ? `rgba(242,96,106,${0.018 + look.bloom * 0.06})`
              : `rgba(112,137,151,${0.02 + look.fog * 0.075})`
          );
          grad.addColorStop(0.45, `rgba(44,75,86,${0.018 + look.fog * 0.045})`);
          grad.addColorStop(1, 'rgba(5,7,9,0)');
          ctx.fillStyle = grad;
          ctx.fillRect(x - radius, y - radius, radius * 2, radius * 2);
        }
        ctx.globalCompositeOperation = 'screen';
        const bands = 3 + Math.round(look.energy * 5);
        for (let i = 0; i < bands; i++) {
          ctx.beginPath();
          for (let x = -20; x <= w + 20; x += 18) {
            const y =
              h * (0.18 + (i / (bands + 1)) * 0.68) +
              Math.sin(x * 0.006 + t * 0.3 + i) * (18 + look.fog * 46);
            x < 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
          }
          ctx.strokeStyle = `rgba(${70 + i * 4},${112 + i * 3},124,${0.015 + look.energy * 0.022})`;
          ctx.lineWidth = 1 + look.bloom * 2;
          ctx.stroke();
        }
        const splitGate = reduced
          ? 0
          : Math.max(0, (Math.sin(t * 0.31) - 0.84) / 0.16) * look.split;
        if (splitGate > 0 && channelCtx) {
          const separation = 2 + splitGate * 10;
          channelCtx.globalCompositeOperation = 'copy';
          channelCtx.drawImage(feedbackCanvas, 0, 0);
          channelCtx.globalCompositeOperation = 'source-in';
          channelCtx.fillStyle = `rgba(69,200,232,${0.16 * splitGate})`;
          channelCtx.fillRect(0, 0, w, h);
          ctx.globalCompositeOperation = 'screen';
          ctx.drawImage(channelCanvas, separation, 0);
          channelCtx.globalCompositeOperation = 'copy';
          channelCtx.drawImage(feedbackCanvas, 0, 0);
          channelCtx.globalCompositeOperation = 'source-in';
          channelCtx.fillStyle = `rgba(242,96,106,${0.13 * splitGate})`;
          channelCtx.fillRect(0, 0, w, h);
          ctx.drawImage(channelCanvas, -separation, 0);
        }
        ctx.globalCompositeOperation = 'source-over';
        for (let i = 0; i < Math.round(70 + look.energy * 170); i++) {
          const n = Math.sin(i * 91.17 + t * 0.07) * 43758.5453;
          const m = Math.sin(i * 47.11 + t * 0.05) * 24634.6345;
          ctx.fillStyle = `rgba(220,226,230,${0.012 + look.energy * 0.02})`;
          ctx.fillRect((n - Math.floor(n)) * w, (m - Math.floor(m)) * h, 1, 1);
        }
        if (!reduced) {
          visualTime += 0.16;
          requestAnimationFrame(drawField);
        }
      };
      resizeField();
      addEventListener('resize', resizeField, { passive: true });
      drawField();

      const setActiveStage = (stage: number) => {
        root.dataset.scene = String(stage);
        targetLook = { ...(sceneLooks[stage] || sceneLooks[0]) };
        if (reduced) drawField();
        railLinks.forEach((link, index) => {
          if (index === stage) link.setAttribute('aria-current', 'step');
          else link.removeAttribute('aria-current');
          link.classList.toggle('is-complete', index < stage);
        });
      };

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (!(visible?.target instanceof HTMLElement)) return;
            const stage = Number(visible.target.dataset.stage || 0);
            setActiveStage(stage);
            if (!visible.target.dataset.revealed) {
              visible.target.dataset.revealed = 'true';
              const heading =
                visible.target.querySelector<HTMLElement>('h1, h2');
              const blocks = Array.from(
                visible.target.querySelectorAll<HTMLElement>(
                  '.section-intro > p, .hero-copy > p, .hero-actions, .run-console, .build-demo, .operator-strip, .cue-context, .live-console, .systems-map, .telemetry-bar, .final-next'
                )
              );
              if (heading)
                heading.animate(
                  reduced
                    ? [{ opacity: 0 }, { opacity: 1 }]
                    : [
                        {
                          clipPath: 'inset(100% 0 0)',
                          transform: 'translateY(24px)'
                        },
                        { clipPath: 'inset(0 0 0)', transform: 'translateY(0)' }
                      ],
                  {
                    duration: reduced ? 1 : 640,
                    easing: 'cubic-bezier(.22, 1, .36, 1)',
                    fill: 'both'
                  }
                );
              blocks.forEach((block, index) =>
                block.animate(
                  reduced
                    ? [{ opacity: 0 }, { opacity: 1 }]
                    : [
                        { opacity: 0, transform: 'translateY(18px)' },
                        { opacity: 1, transform: 'translateY(0)' }
                      ],
                  {
                    duration: reduced ? 1 : 600,
                    delay: reduced ? 0 : 80 + index * 70,
                    easing: 'cubic-bezier(.22, 1, .36, 1)',
                    fill: 'both'
                  }
                )
              );
            }
          },
          { rootMargin: '-24% 0px -55% 0px', threshold: [0.08, 0.25, 0.5] }
        );
        sections.forEach((section) => observer.observe(section));
      }

      let nowIndex = 0;
      const nowNumber = root.querySelector<HTMLElement>('[data-now-number]');
      const nowName = root.querySelector<HTMLElement>('[data-now-name]');
      const nowTime = root.querySelector<HTMLElement>('[data-now-time]');
      const nextNumber = root.querySelector<HTMLElement>('[data-next-number]');
      const nextName = root.querySelector<HTMLElement>('[data-next-name]');
      const nextIntent = root.querySelector<HTMLElement>('[data-next-intent]');
      const goTarget = root.querySelector<HTMLElement>('[data-go-target]');
      const progress = root.querySelector<HTMLElement>('[data-progress]');
      const heroGo = root.querySelector<HTMLButtonElement>('[data-hero-go]');
      const runConsole = root.querySelector<HTMLElement>('.run-console');

      const renderCue = (startProgress = false) => {
        const current = cueStates[nowIndex];
        const next = cueStates[(nowIndex + 1) % cueStates.length];
        if (nowNumber) nowNumber.textContent = current.number;
        if (nowName) nowName.textContent = current.name;
        if (nowTime) nowTime.textContent = current.time;
        if (nextNumber) nextNumber.textContent = next.number;
        if (nextName) nextName.textContent = next.name;
        if (nextIntent) nextIntent.textContent = current.intent;
        if (goTarget) goTarget.textContent = `Run cue ${next.number}`;
        if (progress) {
          progress.classList.remove('is-running');
          if (startProgress)
            requestAnimationFrame(() => progress.classList.add('is-running'));
        }
      };

      const advanceCue = () => {
        nowIndex = (nowIndex + 1) % cueStates.length;
        targetLook = {
          ...targetLook,
          fog: Math.min(0.9, targetLook.fog + 0.18),
          split: 0.34
        };
        renderCue(true);
      };

      heroGo?.addEventListener('click', advanceCue);
      runConsole?.addEventListener('keydown', (event) => {
        if (event.code === 'Space' && event.target === runConsole) {
          event.preventDefault();
          advanceCue();
        }
      });
      renderCue(false);

      const buildDemo = root.querySelector<HTMLElement>('[data-build-demo]');
      if (buildDemo) {
        const resourceButtons = Array.from(
          buildDemo.querySelectorAll<HTMLButtonElement>('[data-resource]')
        );
        const triggerButtons = Array.from(
          buildDemo.querySelectorAll<HTMLButtonElement>('[data-trigger]')
        );
        const actionName =
          buildDemo.querySelector<HTMLElement>('[data-action-name]');
        const actionTarget = buildDemo.querySelector<HTMLOutputElement>(
          '[data-action-target]'
        );
        const summary = buildDemo.querySelector<HTMLElement>(
          '[data-flow-summary]'
        );
        const fogField =
          buildDemo.querySelector<HTMLElement>('[data-fog-field]');
        const fogOutput =
          buildDemo.querySelector<HTMLOutputElement>('[data-fog-output]');
        const buildGo =
          buildDemo.querySelector<HTMLButtonElement>('[data-build-go]');
        let selectedResource = resourceButtons[0];
        let selectedTrigger = triggerButtons[0];

        const renderBuild = () => {
          const resource =
            selectedResource?.dataset.resource || 'Smoke_Field.nblock';
          const parameter =
            selectedResource?.dataset.parameter || 'Fog density';
          const target = selectedResource?.dataset.target || '0.8';
          const trigger = selectedTrigger?.dataset.trigger || 'ON PLAY';
          if (actionName) actionName.textContent = parameter;
          if (actionTarget) actionTarget.textContent = target;
          if (summary)
            summary.textContent = `${resource} → ${parameter} 0.0 → ${target} → ${trigger}`;
        };

        resourceButtons.forEach((button) => {
          button.addEventListener('click', () => {
            selectedResource = button;
            resourceButtons.forEach((item) => {
              const selected = item === button;
              item.classList.toggle('is-selected', selected);
              item.setAttribute('aria-pressed', String(selected));
            });
            renderBuild();
          });
        });

        triggerButtons.forEach((button) => {
          button.addEventListener('click', () => {
            selectedTrigger = button;
            triggerButtons.forEach((item) => {
              const selected = item === button;
              item.classList.toggle('is-selected', selected);
              item.setAttribute('aria-pressed', String(selected));
            });
            renderBuild();
          });
        });

        buildGo?.addEventListener('click', () => {
          const target = selectedResource?.dataset.target || '0.8';
          const targetNumber = Number(target);
          buildDemo.classList.remove('is-running');
          fogField?.style.setProperty('--fog-level', '0');
          if (fogOutput) fogOutput.textContent = '0.00';
          requestAnimationFrame(() => {
            buildDemo.classList.add('is-running');
            fogField?.style.setProperty('--fog-level', target);
            if (fogOutput) {
              if (reduced) fogOutput.textContent = targetNumber.toFixed(2);
              else {
                const start = performance.now();
                const updateFogReadout = (time: number) => {
                  const progress = Math.min(1, (time - start) / 1000);
                  const eased = 1 - Math.pow(1 - progress, 4);
                  fogOutput.textContent = (targetNumber * eased).toFixed(2);
                  if (progress < 1) requestAnimationFrame(updateFogReadout);
                };
                requestAnimationFrame(updateFogReadout);
              }
            }
            targetLook = {
              ...targetLook,
              fog: targetNumber,
              bloom: 0.62,
              energy: 0.7
            };
          });
        });
        renderBuild();
      }

      const liveConsole = root.querySelector<HTMLElement>(
        '[data-live-console]'
      );
      if (liveConsole) {
        const slider =
          liveConsole.querySelector<HTMLInputElement>('[data-osc-slider]');
        const oscValue =
          liveConsole.querySelector<HTMLOutputElement>('[data-osc-value]');
        const liveOutput =
          liveConsole.querySelector<HTMLOutputElement>('[data-live-output]');
        const liveMeter =
          liveConsole.querySelector<HTMLOutputElement>('[data-live-meter]');
        const meter =
          liveConsole.querySelector<HTMLElement>('[data-fog-meter]');
        const fog = liveConsole.querySelector<HTMLElement>('[data-live-fog]');
        const midiButton =
          liveConsole.querySelector<HTMLButtonElement>('[data-midi-pulse]');
        const midiValue =
          liveConsole.querySelector<HTMLOutputElement>('[data-midi-value]');
        const bloomSlider = liveConsole.querySelector<HTMLInputElement>(
          '[data-bloom-slider]'
        );
        const particleSlider = liveConsole.querySelector<HTMLInputElement>(
          '[data-particle-slider]'
        );
        const bloomOutput = liveConsole.querySelector<HTMLOutputElement>(
          '[data-bloom-output]'
        );
        const particleOutput = liveConsole.querySelector<HTMLOutputElement>(
          '[data-particle-output]'
        );
        const bloomMeter =
          liveConsole.querySelector<HTMLElement>('[data-bloom-meter]');
        const particleMeter = liveConsole.querySelector<HTMLElement>(
          '[data-particle-meter]'
        );
        const timecodeOutput = liveConsole.querySelector<HTMLOutputElement>(
          '[data-timecode-output]'
        );
        let lastManualLiveUpdate = 0;

        const renderLive = () => {
          const raw = Number(slider?.value || 64);
          const value = (raw / 100).toFixed(2);
          if (oscValue) oscValue.textContent = value;
          if (liveOutput) liveOutput.textContent = value;
          if (liveMeter) liveMeter.textContent = `${raw}%`;
          if (meter) meter.style.width = `${raw}%`;
          fog?.style.setProperty('--fog-level', String(raw / 100));
          targetLook.fog = raw / 100;
          const bloom = Number(bloomSlider?.value || 48);
          const particles = Number(particleSlider?.value || 66);
          targetLook.bloom = bloom / 100;
          targetLook.energy = particles / 100;
          if (bloomOutput) bloomOutput.textContent = (bloom / 40).toFixed(2);
          if (particleOutput)
            particleOutput.textContent = `${Math.round(particles * 12.12)}k`;
          if (bloomMeter) bloomMeter.style.width = `${bloom}%`;
          if (particleMeter) particleMeter.style.width = `${particles}%`;
        };
        const renderManualLive = () => {
          lastManualLiveUpdate = Date.now();
          renderLive();
        };
        slider?.addEventListener('input', renderManualLive);
        bloomSlider?.addEventListener('input', renderManualLive);
        particleSlider?.addEventListener('input', renderManualLive);
        midiButton?.addEventListener('click', () => {
          const next = Math.round(32 + Math.random() * 95);
          if (midiValue) midiValue.textContent = String(next);
          midiButton.classList.remove('is-pulsing');
          requestAnimationFrame(() => midiButton.classList.add('is-pulsing'));
        });
        renderLive();
        if (!reduced) {
          let timecodeFrames = (1 * 60 * 60 + 12 * 60 + 8) * 25 + 14;
          let liveTicks = 0;
          window.setInterval(() => {
            if (root.dataset.scene !== '3') return;
            timecodeFrames += 5;
            const totalSeconds = Math.floor(timecodeFrames / 25);
            const frames = timecodeFrames % 25;
            const seconds = totalSeconds % 60;
            const minutes = Math.floor(totalSeconds / 60) % 60;
            const hours = Math.floor(totalSeconds / 3600) % 24;
            if (timecodeOutput)
              timecodeOutput.textContent = [hours, minutes, seconds, frames]
                .map((part) => String(part).padStart(2, '0'))
                .join(':');
            liveTicks += 1;
            if (
              liveTicks % 3 === 0 &&
              Date.now() - lastManualLiveUpdate > 1600
            ) {
              if (slider) {
                const base = Number(slider.value);
                slider.value = String(
                  Math.max(0, Math.min(100, base + (liveTicks % 2 ? 1 : -1)))
                );
              }
              renderLive();
              if (midiValue)
                midiValue.textContent = String(72 + ((liveTicks * 7) % 42));
              midiButton?.classList.remove('is-pulsing');
              requestAnimationFrame(() =>
                midiButton?.classList.add('is-pulsing')
              );
            }
          }, 200);
        }
      }

      const runGo = root.querySelector<HTMLButtonElement>('[data-run-go]');
      let runAdvanced = false;
      runGo?.addEventListener('click', () => {
        if (runAdvanced) return;
        runAdvanced = true;
        const now = root.querySelector<HTMLElement>('.operator-now');
        const next = root.querySelector<HTMLElement>('.operator-next');
        const playingRow = root.querySelector<HTMLElement>('.cue-row.playing');
        const nextRow = root.querySelector<HTMLElement>('.cue-row.next');
        const attachedActions =
          root.querySelector<HTMLElement>('.attached-actions');
        const setText = (selector: string, value: string) => {
          const element = root.querySelector<HTMLElement>(selector);
          if (element) element.textContent = value;
        };
        if (now) {
          setText('.operator-now > b', '08');
          setText('.operator-now > strong', 'Smoke Field');
          setText('.operator-now time', '00:00.0');
          setText('.operator-now .time-pair small', 'hold');
          now.animate(
            reduced
              ? [{ opacity: 0.5 }, { opacity: 1 }]
              : [
                  {
                    transform: 'translateX(100%)',
                    background: '#121a16',
                    borderColor: '#57c878'
                  },
                  {
                    transform: 'translateX(0)',
                    background: '#1f1518',
                    borderColor: '#f2606a'
                  }
                ],
            {
              duration: reduced ? 1 : 900,
              easing: 'cubic-bezier(.22, 1, .36, 1)'
            }
          );
          const runProgress = now.querySelector<HTMLElement>(':scope > i');
          runProgress?.classList.remove('is-running');
          requestAnimationFrame(() => runProgress?.classList.add('is-running'));
        }
        setText('.operator-next > b', '09');
        setText('.operator-next > strong', 'Leaves_Cold_Snowflakes');
        setText('.operator-next > small', 'Program · L3 · 03:10.0');
        next?.animate(
          reduced
            ? [{ opacity: 0.5 }, { opacity: 1 }]
            : [
                { transform: 'translateX(24px)', opacity: 0 },
                { transform: 'translateX(0)', opacity: 1 }
              ],
          {
            duration: reduced ? 1 : 340,
            delay: reduced ? 0 : 360,
            easing: 'cubic-bezier(.22, 1, .36, 1)'
          }
        );
        if (playingRow) {
          playingRow.querySelector(':scope > b')!.textContent = '08';
          playingRow.querySelector('strong')!.textContent = 'Smoke Field';
          playingRow.querySelector('small')!.textContent =
            'Program · L2 · hold';
        }
        if (nextRow) {
          nextRow.querySelector(':scope > b')!.textContent = '09';
          nextRow.querySelector('strong')!.textContent =
            'Leaves_Cold_Snowflakes';
          nextRow.querySelector('small')!.textContent =
            'Program · L3 · 03:10.0';
        }
        if (attachedActions)
          attachedActions.innerHTML =
            '<div><i class="running"></i><span>08.1 · Fog density</span><b>0 → 0.8</b></div><div><i class="running"></i><span>08.2 · Bloom</span><b>0.4 → 1.2</b></div><div><i class="live"></i><span>08.3 · Fog density</span><b>OSC · 0.64</b></div>';
        setText('[data-run-inspector-title]', '08 · Smoke Field');
        setText('[data-run-inspector-state]', '● PLAYING');
        setText('[data-run-resource]', 'Smoke_Field.nblock');
        setText('[data-run-duration]', 'hold');
        setText('[data-run-output]', 'Program · L2');
        setText('[data-run-actions]', '3 · running');
        setText('[data-run-live-label]', 'FOG DENSITY');
        setText('[data-run-live-value]', '0.00 → 0.80 · ON PLAY');
        const targetLabel = runGo.querySelector('small');
        if (targetLabel) targetLabel.textContent = 'CUE 09 READY';
        targetLook = { ...targetLook, energy: 0.82, bloom: 0.7 };
      });

      root.querySelectorAll<HTMLElement>('[data-route]').forEach((node) => {
        const toggle = (active: boolean) =>
          (node.dataset.route || '')
            .split(',')
            .forEach((route) =>
              root
                .querySelector<SVGPathElement>(`[data-route-path="${route}"]`)
                ?.classList.toggle('is-route-active', active)
            );
        node.addEventListener('pointerenter', () => toggle(true));
        node.addEventListener('pointerleave', () => toggle(false));
        node.addEventListener('focus', () => toggle(true));
        node.addEventListener('blur', () => toggle(false));
      });

      const finalGo = root.querySelector<HTMLButtonElement>('[data-final-go]');
      const inspector = root.querySelector<HTMLElement>(
        '[data-access-inspector]'
      );
      finalGo?.addEventListener('click', () => {
        targetLook = { fog: 0, bloom: 0, energy: 0, split: 0 };
        canvas?.animate(
          [{ opacity: 1 }, { opacity: 0.06 }, { opacity: 0.28 }],
          {
            duration: reduced ? 1 : 1050,
            easing: 'cubic-bezier(.22, 1, .36, 1)',
            fill: 'forwards'
          }
        );
        inspector?.removeAttribute('hidden');
        inspector?.removeAttribute('inert');
        if (inspector) {
          void inspector.offsetHeight;
          inspector.classList.add('is-visible');
        }
        inspector
          ?.querySelector<HTMLInputElement>('input')
          ?.focus({ preventScroll: true });
        finalGo.disabled = true;
        finalGo.querySelector('small')!.textContent = 'SEQUENCE COMPLETE';
      });
    });
</script>

