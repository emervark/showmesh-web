  .cue-identity {
    display: grid;
    grid-template-columns: 46px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: baseline;
    margin-top: 8px;
  }
  .cue-identity > b {
    color: var(--sm-text-muted);
    font: 22px/1 var(--mono);
  }
  .now-block .cue-identity > b {
    color: var(--sm-playing);
  }
  .next-block .cue-identity > b {
    color: var(--sm-ready);
  }
  .cue-identity strong {
    overflow: hidden;
    color: var(--sm-text-strong);
    font-size: 17px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cue-identity time,
  .cue-identity small {
    color: var(--sm-text-muted);
    font: 11px/1.4 var(--mono);
  }
  .progress-track {
    height: 5px;
    margin: 14px 0 12px 58px;
    overflow: hidden;
    background: rgb(255 255 255 / 7%);
  }
  .progress-track span {
    display: block;
    width: 62%;
    height: 100%;
    background: var(--sm-playing);
  }
  .progress-track span.is-running {
    animation: cue-progress 8s linear forwards;
  }
  @keyframes cue-progress {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }
  .action-chain {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-left: 58px;
  }
  .action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--sm-text-muted);
    font: 9px/1.4 var(--mono);
  }
  .action i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sm-text-faint);
  }
  .action.running {
    color: var(--sm-playing);
  }
  .action.running i {
    background: var(--sm-playing);
  }
  .action.live {
    color: var(--sm-live);
  }
  .action.live i {
    background: var(--sm-live);
  }
  .go-row {
    display: grid;
    grid-template-columns: minmax(180px, 0.46fr) 1fr;
    gap: 18px;
    align-items: center;
    padding: 14px;
    border-top: 1px solid var(--sm-border);
    background: var(--sm-bg-elevated);
  }
  .go-button,
  .mini-go,
  .final-go-button {
    min-height: 58px;
    border: 1px solid #43b66b;
    border-radius: var(--sm-radius-control);
    background: var(--sm-go);
    color: #07120b;
    font-weight: 800;
  }
  .go-button {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: center;
    padding: 0 18px;
    text-align: left;
  }
  .go-button span {
    font-size: 23px;
  }
  .go-button small {
    justify-self: end;
    font: 10px/1.3 var(--mono);
  }
  .go-button:hover,
  .mini-go:hover,
  .final-go-button:hover {
    background: var(--sm-ready);
  }
  .go-hint {
    color: var(--sm-text-muted);
    font: 10px/1.4 var(--mono);
  }
  .section-intro {
    max-width: 760px;
    margin-bottom: 56px;
  }
  .section-intro.narrow {
    max-width: 690px;
  }
  .cue-index {
    color: var(--sm-ready);
    font: 11px/1.4 var(--mono);
    letter-spacing: 0.06em;
  }
  .section-intro h2 {
    margin: 12px 0 16px;
    color: var(--sm-text-strong);
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.045em;
  }
  .section-intro p {
    max-width: 650px;
    margin: 0;
    color: var(--sm-text-secondary);
    font-size: 18px;
  }
  .build-section,
  .live-section {
    background: rgb(20 23 29 / 89%);
  }
  .build-demo {
    overflow: hidden;
  }
  .build-preview {
    position: relative;
    min-height: 220px;
    overflow: hidden;
    border-bottom: 1px solid var(--sm-border);
    background: #090b0e;
  }
  .fog-field,
  .parameter-visual {
    --fog-level: 0;
  }
  .fog-field {
    position: absolute;
    inset: 0;
    opacity: calc(0.08 + var(--fog-level) * 0.9);
    transition: opacity 1000ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fog-field span,
  .parameter-visual > span {
    position: absolute;
    border-radius: 50%;
    background: rgb(222 226 232 / 12%);
    filter: blur(30px);
  }
  .fog-field span:first-child {
    inset: 40% 45% -30% -10%;
  }
  .fog-field span:nth-child(2) {
    inset: 15% 8% 30% 50%;
  }
  .fog-field span:nth-child(3) {
    inset: 55% 20% -50% 20%;
  }
  .preview-readout {
    position: absolute;
    right: 18px;
    bottom: 16px;
    left: 18px;
    display: flex;
    justify-content: space-between;
    align-items: end;
    color: var(--sm-text-muted);
    font: 10px/1.4 var(--mono);
  }
  .preview-readout b {
    color: var(--sm-live);
    font-size: 13px;
  }
  .flow-editor {
    display: grid;
    grid-template-columns:
      minmax(210px, 1fr) 48px minmax(180px, 0.8fr)
      48px minmax(180px, 0.8fr) 120px;
    align-items: stretch;
    padding: 24px;
  }
  .flow-stage {
    min-width: 0;
  }
  .is-choreographed [data-stage='1']:not([data-revealed]) .flow-stage,
  .is-choreographed [data-stage='1']:not([data-revealed]) .flow-link {
    opacity: 0;
  }
  [data-stage='1'][data-revealed] .resource-stage {
    animation: assemble-from-left 640ms cubic-bezier(0.22, 1, 0.36, 1) 160ms
      both;
  }
  [data-stage='1'][data-revealed] .action-stage {
    animation: assemble-from-bottom 640ms cubic-bezier(0.22, 1, 0.36, 1) 240ms
      both;
  }
  [data-stage='1'][data-revealed] .trigger-stage {
    animation: assemble-from-right 640ms cubic-bezier(0.22, 1, 0.36, 1) 320ms
      both;
  }
  [data-stage='1'][data-revealed] .flow-link {
    animation: reveal-connector 600ms cubic-bezier(0.22, 1, 0.36, 1) 480ms both;
  }
  @keyframes assemble-from-left {
    from {
      opacity: 0;
      transform: translateX(-28px);
    }
  }
  @keyframes assemble-from-bottom {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
  }
  @keyframes assemble-from-right {
    from {
      opacity: 0;
      transform: translateX(28px);
    }
  }
  @keyframes reveal-connector {
    from {
      opacity: 0;
      clip-path: inset(0 100% 0 0);
    }
    to {
      opacity: 1;
      clip-path: inset(0);
    }
  }
  .resource-list,
  .trigger-options {
    display: grid;
    gap: 4px;
    margin-top: 10px;
  }
  .resource-list button,
  .trigger-options button {
    min-height: 38px;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 0 10px;
    background: var(--sm-bg-soft);
    color: var(--sm-text-muted);
    font-size: 12px;
    text-align: left;
  }
  .resource-list button.is-selected,
  .trigger-options button.is-selected {
    border-color: rgb(69 200 232 / 45%);
    background: rgb(69 200 232 / 8%);
    color: var(--sm-live);
  }
  .action-value {
    margin-top: 10px;
    border-left: 2px solid var(--sm-ready);
    padding: 10px 12px;
    background: var(--sm-bg-soft);
  }
  .action-value > span {
    display: block;
    color: var(--sm-text-primary);
    font-size: 12px;
  }
  .action-value b {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 12px;
    color: var(--sm-text-strong);
    font: 18px/1 var(--mono);
  }
  .action-value b i,
  .action-value b em {
    color: var(--sm-text-muted);
    font-style: normal;
  }
  .action-value small {
    color: var(--sm-text-faint);
    font: 9px/1.4 var(--mono);
  }
  .flow-link {
    position: relative;
  }
  .flow-link::before {
    position: absolute;
    top: 64px;
    right: 8px;
    left: 8px;
    height: 1px;
    background: var(--sm-border-strong);
    content: '';
  }
  .flow-link i {
    position: absolute;
    top: 60px;
    right: 6px;
    width: 9px;
    height: 9px;
    border: 1px solid var(--sm-live);
    background: var(--sm-bg-panel);
    transform: rotate(45deg);
  }
  .mini-go {
    align-self: center;
    display: grid;
    place-content: center;
    margin: 18px 0 0 16px;
  }
  .mini-go span {
    font-size: 20px;
  }
  .mini-go small {
    font: 9px/1.3 var(--mono);
  }
  .flow-summary {
    min-height: 44px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 24px;
    border-top: 1px solid var(--sm-border);
    color: var(--sm-text-muted);
    font: 10px/1.4 var(--mono);
  }
  .flow-summary i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sm-ready);
  }
  .operator-strip {
    display: grid;
    grid-template-columns: 1.15fr 1fr 160px;
    overflow: hidden;
    border: 1px solid var(--sm-border-strong);
    border-radius: var(--sm-radius-panel) var(--sm-radius-panel) 0 0;
    background: var(--sm-bg-panel);
  }
  .operator-now,
  .operator-next {
    position: relative;
    display: grid;
    grid-template-columns: 56px 44px minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
    min-height: 94px;
    padding: 14px 18px;
  }
  .operator-now {
    border-left: 4px solid var(--sm-playing);
    background: #1f1518;
  }
  .operator-next {
    grid-template-columns: 44px 36px minmax(0, 1fr);
    border-left: 4px solid var(--sm-ready);
    background: #121a16;
  }
  .operator-now > span,
  .operator-next > span {
    color: var(--sm-playing);
    font: 9px/1.3 var(--mono);
  }
  .operator-next > span {
    color: var(--sm-ready);
  }
  .operator-now > b,
  .operator-next > b {
    color: var(--sm-text-muted);
    font: 20px/1 var(--mono);
  }
  .operator-now > strong,
  .operator-next > strong {
    overflow: hidden;
    color: var(--sm-text-strong);
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .operator-next > small {
    grid-column: 3;
    color: var(--sm-text-muted);
    font: 9px/1.3 var(--mono);
  }
  .time-pair {
    display: grid;
    text-align: right;
  }
  .time-pair time {
    color: var(--sm-text-primary);
    font: 14px/1.3 var(--mono);
  }
  .time-pair small {
    color: var(--sm-text-muted);
    font: 10px/1.3 var(--mono);
  }
  .operator-now > i {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 4px;
    background: var(--sm-playing);
    transform: scaleX(0.62);
    transform-origin: left;
  }
  .operator-now > i.is-running {
    animation: operator-progress 8s linear forwards;
  }
  @keyframes operator-progress {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
  .operator-go {
    display: grid;
    place-content: center;
    background: var(--sm-go);
    color: #07120b;
    text-align: center;
  }
  .operator-go span {
    font-size: 23px;
    font-weight: 850;
  }
  .operator-go small {
    font: 9px/1.2 var(--mono);
  }
  .cue-context {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    border: 1px solid var(--sm-border-strong);
    border-top: 0;
    background: var(--sm-bg-panel);
  }
  .cue-list-fragment {
    padding: 18px;
  }
  .cue-row {
    position: relative;
    display: grid;
    grid-template-columns: 4px 46px 1fr auto;
    gap: 12px;
    min-height: 58px;
    align-items: center;
    border-radius: 5px;
    padding: 0 14px 0 0;
    background: var(--sm-bg-soft);
  }
  .cue-row + .cue-row {
    margin-top: 6px;
  }
  .cue-row .rail {
    align-self: stretch;
    background: transparent;
  }
  .cue-row.playing {
    background: #1f1518;
  }
  .cue-row.playing .rail {
    background: var(--sm-playing);
  }
  .cue-row.next .rail {
    background: var(--sm-ready);
  }
  .cue-row > b {
    color: var(--sm-text-muted);
    font: 16px/1 var(--mono);
  }
  .cue-row > div {
    display: grid;
  }
  .cue-row strong {
    color: var(--sm-text-primary);
    font-size: 13px;
  }
  .cue-row small {
    color: var(--sm-text-muted);
    font: 9px/1.4 var(--mono);
  }
  .cue-row em {
    color: var(--sm-text-faint);
    font: 9px/1 var(--mono);
    font-style: normal;
  }
  .cue-row.playing em {
    color: var(--sm-playing);
  }
  .cue-row.next em {
    color: var(--sm-ready);
  }
  .cue-row.warning small,
  .cue-row.warning em {
    color: var(--sm-warning);
  }
  .attached-actions {
    display: grid;
    gap: 5px;
    padding: 10px 26px 12px 62px;
    background: #1a1215;
  }
  .attached-actions div {
    display: grid;
    grid-template-columns: 8px 1fr auto;
    gap: 8px;
    align-items: center;
    color: var(--sm-text-muted);
    font: 10px/1.4 var(--mono);
  }
  .attached-actions i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sm-text-faint);
  }
  .attached-actions i.running {
    background: var(--sm-playing);
  }
  .attached-actions i.live {
    background: var(--sm-live);
  }
  .attached-actions div:nth-child(2) b {
    color: var(--sm-playing);
  }
  .attached-actions div:nth-child(3) b {
    color: var(--sm-live);
  }
  .inspector-fragment {
    border-left: 1px solid var(--sm-border);
    background: var(--sm-bg-elevated);
  }
  .inspector-title {
    display: grid;
    gap: 4px;
    padding: 16px;
    border-bottom: 1px solid var(--sm-border);
  }
  .inspector-title span,
  .inspector-title small {
    color: var(--sm-text-muted);
    font: 9px/1.3 var(--mono);
  }
  .inspector-title b {
    color: var(--sm-text-primary);
    font-size: 13px;
  }
  .inspector-title small {
    color: var(--sm-ready);
  }
  .inspector-fragment dl {
    margin: 0;
  }
  .inspector-fragment dl div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 10px;
    padding: 11px 16px;
    border-bottom: 1px solid var(--sm-border);
  }
  .inspector-fragment dt,
  .inspector-fragment dd {
    margin: 0;
    font: 9px/1.4 var(--mono);
  }
  .inspector-fragment dt {
    color: var(--sm-text-faint);
  }
  .inspector-fragment dd {
    color: var(--sm-text-secondary);
  }
  .inspector-fragment .live-field dd {
    color: var(--sm-live);
  }
  .live-console {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    overflow: hidden;
  }
  .live-inputs {
    padding: 22px;
    border-right: 1px solid var(--sm-border);
  }
  .input-row {
    width: 100%;
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 12px;
    align-items: center;
    min-height: 50px;
    border: 0;
    border-bottom: 1px solid var(--sm-border);
    padding: 0;
    background: transparent;
    color: var(--sm-text-muted);
    font: 10px/1.4 var(--mono);
    text-align: left;
  }
  button.input-row:hover {
    background: var(--sm-bg-soft);
  }
  .input-row span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .input-row span i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sm-text-faint);
  }
  .input-row.active span,
  .input-row.active output {
    color: var(--sm-live);
  }
  .input-row.active span i {
    background: var(--sm-live);
  }
  .input-row b {
    color: var(--sm-text-secondary);
    font-weight: 500;
  }
  .input-row output {
    color: var(--sm-text-primary);
  }
  .input-row.is-pulsing span i {
    background: var(--sm-live);
  }
  .value-slider {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    align-items: center;
    padding: 12px 0 16px;
    color: var(--sm-text-faint);
    font: 9px/1.4 var(--mono);
  }
  .value-slider input {
    accent-color: var(--sm-live);
  }
  .parameter-monitor {
    min-width: 0;
  }
  .monitor-head {
    min-height: 46px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 18px;
    border-bottom: 1px solid var(--sm-border);
    color: var(--sm-text-muted);
    font: 9px/1.3 var(--mono);
  }
  .monitor-head b {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--sm-live);
  }
  .monitor-head i {
    background: var(--sm-live);
  }
  .parameter-visual {
    position: relative;
    min-height: 260px;
    overflow: hidden;
    display: grid;
    place-content: center;
    background: #090b0e;
  }
  .parameter-visual > span {
    opacity: calc(0.08 + var(--fog-level) * 0.72);
    transition: opacity 160ms ease;
  }
  .parameter-visual .fog-a {
    inset: 48% 42% -30% -10%;
  }
  .parameter-visual .fog-b {
    inset: 8% -4% 42% 48%;
  }
  .parameter-visual .fog-c {
    inset: 58% 12% -48% 28%;
  }
  .parameter-visual strong,
  .parameter-visual output {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .parameter-visual strong {
    color: var(--sm-text-faint);
    font: 10px/1.4 var(--mono);
  }
  .parameter-visual output {
    color: var(--sm-live);
    font: 44px/1 var(--mono);
  }
  .meter-list {
    padding: 14px 18px 18px;
  }
  .meter-list > div {
    display: grid;
    grid-template-columns: 100px 1fr 44px;
    gap: 10px;
    align-items: center;
    min-height: 27px;
    color: var(--sm-text-muted);
    font: 9px/1.3 var(--mono);
  }
  .meter-list div > i {
    height: 3px;
    overflow: hidden;
    background: rgb(255 255 255 / 7%);
  }
  .meter-list div > i b {
    display: block;
    height: 100%;
    background: var(--sm-live);
  }
  .meter-list output {
    text-align: right;
  }
  .systems-map {
    position: relative;
    min-height: 430px;
    border-block: 1px solid var(--sm-border);
  }
  .systems-map svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .systems-map path {
    fill: none;
    stroke: rgb(69 200 232 / 32%);
    stroke-width: 1.2;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 8 10;
    animation: signal-route 5s linear infinite;
  }
  .systems-map path.is-route-active {
    stroke: var(--sm-live);
    stroke-width: 2.2;
  }
  @keyframes signal-route {
    to {
      stroke-dashoffset: -72;
    }
  }
  .system-node {
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }
  .system-node:hover,
  .system-node:focus {
    border-color: rgb(69 200 232 / 65%);
    background: #121a20;
    outline: none;
  }
  .system-node,
  .system-core {
    position: absolute;
    z-index: 2;
    display: grid;
    min-width: 180px;
    border: 1px solid var(--sm-border-strong);
    padding: 14px;
    background: var(--sm-bg-panel);
  }
  .system-node span,
  .system-core span {
    color: var(--sm-live);
    font: 9px/1.3 var(--mono);
  }
  .system-node b,
  .system-core b {
    margin-top: 5px;
    color: var(--sm-text-primary);
    font-size: 13px;
  }
  .system-node small,
  .system-core small {
    color: var(--sm-text-faint);
    font: 9px/1.4 var(--mono);
  }
  .system-node.media {
    top: 34px;
    left: 2%;
  }
  .system-node.control {
    top: 34px;
    right: 2%;
  }
  .system-node.realtime {
    bottom: 34px;
    left: 2%;
  }
  .system-node.output {
    right: 2%;
    bottom: 34px;
  }
  .system-core {
    top: 50%;
    left: 50%;
    min-width: 240px;
    border-left: 3px solid var(--sm-ready);
    transform: translate(-50%, -50%);
  }
  .system-core span {
    color: var(--sm-ready);
  }
  .system-core i {
    position: absolute;
    top: 50%;
    right: -5px;
    width: 9px;
    height: 9px;
    background: var(--sm-ready);
    transform: translateY(-50%) rotate(45deg);
  }
  .telemetry-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--sm-border);
