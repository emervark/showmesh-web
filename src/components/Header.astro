<header class="site-header">
  <div class="container nav">
    <a class="brand" href="#top" aria-label="Showmesh home">
      <span class="mark" aria-hidden="true"></span><span>Showmesh</span>
    </a>
    <nav class="desktop-nav" aria-label="Primary navigation">
      <a href="#build">Build a cue</a><a href="#run">Run the show</a><a
        href="#live">Live systems</a
      ><a href="#systems">Engine</a>
    </nav>
    <a class="nav-cta" href="#contact">Request access</a>
    <details class="mobile-nav" data-nav-details>
      <summary aria-label="Open navigation"
        ><span></span><span></span><span></span></summary
      >
      <nav aria-label="Mobile navigation">
        <a href="#build">Build a cue</a><a href="#run">Run the show</a><a
          href="#live">Live systems</a
        ><a href="#systems">Engine</a><a href="#contact">Request access</a>
      </nav>
    </details>
  </div>
</header>
<script>
  const details = document.querySelector('[data-nav-details]');
  if (details instanceof HTMLDetailsElement) {
    const summary = details.querySelector('summary');
    details.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && details.open) {
        details.open = false;
        if (summary instanceof HTMLElement) summary.focus();
      }
    });
    details.querySelectorAll('a').forEach((link) =>
      link.addEventListener('click', () => {
        details.open = false;
      })
    );
  }
</script>
<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    height: 64px;
    border-bottom: 1px solid var(--sm-border);
    background: var(--sm-bg-shell);
  }
  .nav {
    height: 64px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    color: var(--sm-text-strong);
    font-weight: 760;
  }
  .mark {
    width: 11px;
    height: 11px;
    background: var(--sm-ready);
    transform: rotate(45deg);
  }
  .desktop-nav {
    display: flex;
    gap: 28px;
    color: var(--sm-text-muted);
    font-size: 14px;
  }
  nav a:hover {
    color: var(--sm-text-primary);
  }
  .nav-cta {
    justify-self: end;
    border: 1px solid var(--sm-border-strong);
    border-radius: var(--sm-radius-control);
    padding: 8px 12px;
    background: var(--sm-bg-soft);
    font-size: 14px;
    font-weight: 700;
  }
  .mobile-nav {
    display: none;
  }
  @media (max-width: 767px) {
    .nav {
      grid-template-columns: 1fr auto;
    }
    .desktop-nav,
    .nav-cta {
      display: none;
    }
    .mobile-nav {
      position: relative;
      display: block;
    }
    .mobile-nav summary {
      display: grid;
      gap: 4px;
      width: 44px;
      height: 44px;
      place-content: center;
      border-radius: var(--sm-radius-control);
      cursor: pointer;
      list-style: none;
    }
    .mobile-nav summary::-webkit-details-marker {
      display: none;
    }
    .mobile-nav summary span {
      width: 20px;
      height: 1px;
      background: var(--sm-text-primary);
    }
    .mobile-nav nav {
      position: absolute;
      top: 48px;
      right: 0;
      display: grid;
      min-width: 220px;
      border: 1px solid var(--sm-border-strong);
      border-radius: var(--sm-radius-panel);
      padding: 8px;
      background: var(--sm-bg-elevated);
    }
    .mobile-nav nav a {
      min-height: 44px;
      display: flex;
      align-items: center;
      padding: 0 12px;
      border-radius: var(--sm-radius-control);
      color: var(--sm-text-secondary);
    }
    .mobile-nav nav a:hover {
      background: var(--sm-bg-soft);
      color: var(--sm-text-strong);
    }
  }
</style>
