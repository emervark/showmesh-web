<section id="product-ui" class="section interactive-showcase">
  <div class="container">
    <div class="showcase-heading">
      <div class="section-header">
        <span class="kicker">Interactive product UI</span>
        <h2>Operate the interface, not a marketing mockup.</h2>
        <p>
          Select cues, inspect their properties, press GO, and watch current and
          next state advance. Switch views to focus on the parts an operator
          reads under pressure.
        </p>
      </div>
      <div class="showcase-meta">
        <span><i class="status-dot"></i> Interactive prototype</span>
        <span>Space · GO</span>
        <span>Esc · PANIC</span>
      </div>
    </div>

    <div class="ui-demo" data-ui-demo data-view="full">
      <div class="demo-toolbar">
        <div class="view-tabs" role="tablist" aria-label="Product UI view">
          <button
            type="button"
            role="tab"
            aria-selected="true"
            data-demo-view="full">Full workspace</button
          >
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-demo-view="live">Live + next</button
          >
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-demo-view="cues">Cue list</button
          >
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-demo-view="inspector">Inspector</button
          >
        </div>
        <a href="/showmesh-ui.html" target="_blank" rel="noreferrer">
          Open full UI <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div
        class="demo-viewport"
        data-demo-viewport
        role="tabpanel"
        aria-label="Full Showmesh workspace"
      >
        <div class="demo-canvas" data-demo-canvas>
          <iframe
            data-demo-frame
            src="/showmesh-ui.html"
            title="Interactive Showmesh operator interface"
            loading="lazy"></iframe>
        </div>
      </div>

      <div class="demo-caption" aria-live="polite">
        <span data-demo-label>Full workspace</span>
        <p data-demo-description>
          Resources, cue workspace, inspector, live state, and system health in
          one operating context.
        </p>
        <small>Product interaction prototype · features may change</small>
      </div>
    </div>
  </div>
</section>

<script>
  const views = {
    full: {
      x: 0,
      y: 0,
      width: 1600,
      height: 900,
      label: 'Full workspace',
      aria: 'Full Showmesh workspace',
      description:
        'Resources, cue workspace, inspector, live state, and system health in one operating context.'
    },
    live: {
      x: 0,
      y: 40,
      width: 1600,
      height: 94,
      label: 'Live + next',
      aria: 'Current cue, next cue, GO, and PANIC controls',
      description:
        'The playing cue, elapsed and remaining time, next intent, GO target, and separated PANIC control.'
    },
    cues: {
      x: 206,
      y: 155,
      width: 1076,
      height: 650,
      label: 'Cue list',
      aria: 'Showmesh cue list with playing and next states',
      description:
        'A red playing rail, green NEXT rail, cue progress, attached actions, warnings, and local run controls.'
    },
    inspector: {
      x: 1282,
      y: 155,
      width: 318,
      height: 650,
      maxScale: 1.75,
      label: 'Inspector',
      aria: 'Showmesh contextual cue inspector',
      description:
        'Identity, resource, timing, playback, routing, actions, parameters, and notes for the selected cue.'
    }
  } as const;

  document.querySelectorAll<HTMLElement>('[data-ui-demo]').forEach((demo) => {
    const viewport = demo.querySelector<HTMLElement>('[data-demo-viewport]');
    const frame = demo.querySelector<HTMLIFrameElement>('[data-demo-frame]');
    const canvas = demo.querySelector<HTMLElement>('[data-demo-canvas]');
    const label = demo.querySelector<HTMLElement>('[data-demo-label]');
    const description = demo.querySelector<HTMLElement>(
      '[data-demo-description]'
    );
    const buttons = Array.from(
      demo.querySelectorAll<HTMLButtonElement>('[data-demo-view]')
    );

    if (!viewport || !frame || !canvas || !label || !description) return;

    const render = () => {
      const key = (demo.dataset.view || 'full') as keyof typeof views;
      const view = views[key] || views.full;
      const scale = Math.min(
        viewport.clientWidth / view.width,
        'maxScale' in view ? view.maxScale : Number.POSITIVE_INFINITY
      );
      viewport.style.height = `${Math.round(view.height * scale)}px`;
      viewport.setAttribute('aria-label', view.aria);
      canvas.style.transform = `translate(${-view.x * scale}px, ${-view.y * scale}px) scale(${scale})`;
      label.textContent = view.label;
      description.textContent = view.description;
      buttons.forEach((button) => {
        const selected = button.dataset.demoView === key;
        button.setAttribute('aria-selected', String(selected));
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const key = button.dataset.demoView as keyof typeof views;
        if (!key || !views[key]) return;
        demo.dataset.view = key;
        render();
      });
    });

    const resizeObserver = new ResizeObserver(render);
    resizeObserver.observe(viewport);
    frame.addEventListener('load', render, { once: true });
    render();
  });
</script>

