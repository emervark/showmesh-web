---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import InterfaceMock from '../components/InterfaceMock.astro';
const integrations = [
  'Video',
  'Audio',
  'Images',
  'Text',
  'OSC',
  'MIDI',
  'DMX',
  'NDI',
  'Spout',
  'Timecode',
  'Unreal Engine',
  'Notch',
  'TouchDesigner'
];
const features = [
  [
    'Resource',
    'Every file, device, runtime and output is represented as a reusable show object.'
  ],
  [
    'Action',
    'Actions describe what changes: play media, fade opacity, set a parameter or send a control message.'
  ],
  [
    'Trigger',
    'GO, timecode, OSC, MIDI, keyboard and show events can fire actions with clear intent.'
  ]
];
---

<BaseLayout>
  <Header />
  <main id="top">
    <section class="hero container">
      <div class="hero-copy">
        <span class="kicker">Realtime show automation for Windows</span>
        <h1>Connect, automate and run the show.</h1>
        <p>
          Showmesh is a Windows-first application for theatres, concerts,
          immersive installations and live events — built around a clear
          Resource → Action → Trigger model.
        </p>
        <div class="actions">
          <a class="btn primary" href="#contact">Request early access</a><a
            class="btn"
            href="#model">Explore the model</a>
        </div>
      </div>
      <InterfaceMock />
    </section>

    <section id="model" class="section container">
      <div class="section-header">
        <span class="kicker">Core model</span><h2>
          One automation language for the whole show.
        </h2><p>
          Showmesh is not simply “QLab for Windows”. It combines cue-based
          operation, realtime automation and a media playback engine in one
          operator-first workspace.
        </p>
      </div>
      <div class="model-grid">
        {
          features.map(([title, text]) => (
            <article>
              <>
                <span>{title}</span>
                <p>{text}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>

    <section id="systems" class="section systems">
      <div class="container split">
        <div class="section-header">
          <span class="kicker">Connected systems</span><h2>
            Designed for modern production stacks.
          </h2><p>
            Plan, cue and control media, live inputs, show networks and realtime
            engines. Integrations are presented as a roadmap-friendly capability
            model and will be marked by availability as the product matures.
          </p>
        </div>
        <div class="chips">
          {integrations.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section id="interface" class="section container">
      <div class="section-header">
        <span class="kicker">Operator interface</span><h2>
          Dark, calm and built for the room.
        </h2><p>
          The first website uses interface placeholders while the product UI
          evolves. The visual direction is precise, broadcast-inspired and
          focused on show-critical hierarchy: what is playing, what is next and
          what will happen on GO.
        </p>
      </div>
      <div class="principles">
        <article>
          <b>Show-first hierarchy</b><p>
            NOW, NEXT and GO stay above configuration noise.
          </p>
        </article><article>
          <b>Action-centric editing</b><p>
            Actions stay visually attached to the resources they manipulate.
          </p>
        </article><article>
          <b>Professional density</b><p>
            Detailed enough for operators without becoming a generic SaaS
            dashboard.
          </p>
        </article>
      </div>
    </section>

    <section id="deploy" class="section container deploy card">
      <span class="kicker">Static web launch</span><h2>
        Built for Cloudflare Pages.
      </h2><p>
        This marketing site is a static Astro build. Cloudflare Pages settings:
        build command <code>npm run build</code>, output directory <code
          >dist</code
        >.
      </p>
    </section>

    <section id="contact" class="section container contact">
      <span class="kicker">Early access</span><h2>
        Building for theatres, concerts and immersive rooms.
      </h2><p>
        Showmesh is in early development. Use this first site to position the
        product, collect interest and document the automation model as the
        engine becomes production-ready.
      </p><a class="btn primary" href="mailto:hello@showmesh.app"
        >hello@showmesh.app</a
      >
    </section>
  </main>
  <footer>
    <div class="container">
      © 2026 Showmesh. Realtime show automation for Windows.
    </div>
  </footer>
</BaseLayout>
<style>
  .hero {
    padding: 88px 0 72px;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(560px, 1.18fr);
    align-items: center;
    gap: 42px;
  }
  h1 {
    margin: 12px 0 18px;
    font-size: clamp(3.4rem, 8vw, 7.2rem);
    line-height: 0.86;
    letter-spacing: -0.075em;
  }
  .hero-copy p {
    max-width: 620px;
    color: var(--muted);
    font-size: 1.18rem;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .model-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .model-grid article,
  .principles article {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
  }
  .model-grid span {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .model-grid p,
  .principles p {
    color: var(--muted);
    margin-bottom: 0;
  }
  .systems {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.025),
      rgba(255, 255, 255, 0)
    );
    border-block: 1px solid var(--line);
  }
  .split {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 40px;
    align-items: start;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 20px;
  }
  .chips span {
    border: 1px solid var(--line);
    background: rgba(13, 17, 26, 0.68);
    border-radius: 999px;
    padding: 10px 13px;
    color: #c8d2e2;
  }
  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .deploy {
    padding: 38px;
  }
  .deploy h2,
  .contact h2 {
    margin: 10px 0 12px;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }
  code {
    font-family: var(--mono);
    color: var(--accent);
  }
  .contact {
    text-align: center;
    max-width: 820px;
  }
  .contact p {
    color: var(--muted);
    margin-bottom: 24px;
  }
  footer {
    border-top: 1px solid var(--line);
    padding: 28px 0;
    color: var(--muted-2);
    font-size: 0.9rem;
  }
  @media (max-width: 980px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }
    .hero {
      padding-top: 56px;
    }
    .model-grid,
    .principles {
      grid-template-columns: 1fr;
    }
  }
</style>
