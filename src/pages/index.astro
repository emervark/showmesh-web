---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SequenceExperience from '../components/SequenceExperience.astro';
---

<BaseLayout
  title="Showmesh — Everything that makes the show. One sequence that runs it."
  description="Showmesh brings media, realtime graphics, control signals, and external systems into one Windows-native cue sequence."
>
  <Header />
  <main id="main-content">
    <SequenceExperience />
  </main>
  <footer>
    <div class="container">
      <span>© 2026 Showmesh</span>
      <a href="/showmesh-ui.html" target="_blank">Full operator UI</a>
      <a href="mailto:hello@showmesh.app">Contact</a>
      <a href="#top">Back to cue 01</a>
    </div>
  </footer>
</BaseLayout>

<style>
  footer {
    border-top: 1px solid var(--sm-border);
    padding: 28px 0;
    color: var(--sm-text-muted);
    font-size: 13px;
  }
  footer .container {
    display: flex;
    gap: 24px;
  }
  footer span {
    margin-right: auto;
  }
  @media (max-width: 767px) {
    footer .container {
      flex-wrap: wrap;
    }
    footer span {
      width: 100%;
    }
  }
</style>
