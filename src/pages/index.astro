---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const cues = [
  {
    num: '1',
    icon: '▶',
    name: 'House out',
    dur: 2,
    sub: 'Manual — GO when actor says “dog”.'
  },
  {
    num: '2',
    icon: '▶',
    name: 'Opening video',
    dur: 45,
    sub: 'Program · Output A'
  },
  {
    num: '3',
    icon: '⇄',
    name: 'Fade house to 0',
    dur: 3,
    sub: '↳ fades out 1 · House out'
  },
  {
    num: '4',
    icon: '◈',
    name: 'Send OSC /scene/2',
    dur: 1,
    sub: 'OSC → Notch'
  },
  {
    num: '5',
    icon: '⧉',
    name: 'Act I transition',
    dur: 8,
    sub: 'Group · 3 actions'
  },
  {
    num: '6',
    icon: '♪',
    name: 'Underscore loop',
    dur: 120,
    sub: 'Audio · loops'
  }
];

const keyOutcomes = [
  'Fewer disconnected control surfaces during a show',
  'Less manual coordination between media and external systems',
  'A clearer relationship between cues, actions and triggers',
  'Better visibility of current state, next state and system health',
  'One workflow from programming and rehearsal to live operation'
];

const valueCards = [
  {
    icon: '◈',
    color: 'var(--sm-live)',
    tint: 'rgb(69 200 232 / 12%)',
    title: 'Bring the systems together.',
    copy: 'Organise media, outputs, control connections and realtime engines as reusable resources. Keep the systems that make the show visible and available from one project.'
  },
  {
    icon: '⇄',
    color: 'var(--sm-warning)',
    tint: 'rgb(227 169 79 / 12%)',
    title: 'Describe the outcome once.',
    copy: 'Define what should change, when it should happen and what should trigger it. Build repeatable cue behaviour instead of coordinating the same steps by hand every night.'
  },
  {
    icon: '▶',
    color: 'var(--sm-ready)',
    tint: 'rgb(87 200 120 / 12%)',
    title: 'Operate with confidence.',
    copy: 'See the current cue, remaining time, next cue, active actions, incoming control and warnings without losing the run order.'
  }
];

const model = [
  {
    label: 'What can be controlled',
    color: 'var(--sm-live)',
    title: 'Resource',
    copy: 'A video, audio file, image, output, connection, realtime engine or other system used by the show.'
  },
  {
    label: 'What changes',
    color: 'var(--sm-warning)',
    title: 'Action',
    copy: 'Fade a parameter, change volume, route an output, send a command or control another resource.'
  },
  {
    label: 'When it happens',
    color: 'var(--sm-ready)',
    title: 'Trigger',
    copy: 'Cue start, cue stop, timeline position, OSC, MIDI or deliberate manual execution.'
  }
];

const benefits = [
  'Clear current and next cue',
  'Elapsed, remaining and total time',
  'Visible cue and action progress',
  'Live connection and input state',
  'Warnings next to the affected cue',
  'Safe inspection and editing during rehearsal or playback',
  'Deliberate separation between GO and emergency controls'
];

const liveSignals = [
  { label: 'OSC · /scene/2', status: '3 active', pulse: '1.6s' },
  { label: 'MIDI · Note On Ch1', status: 'idle', pulse: '2.1s' },
  { label: 'NDI · Program out', status: 'sending', pulse: '1.3s' }
];

const capabilityGroups = [
  {
    title: 'Media playback',
    copy: 'Video, audio, images and text organised in a cue-based sequence.'
  },
  {
    title: 'Realtime graphics',
    copy: 'Parameters, states and external visual engines controlled from the same show structure.'
  },
  {
    title: 'Outputs and routing',
    copy: 'Program outputs and network video workflows kept visible alongside the cues that use them.'
  },
  {
    title: 'External control',
    copy: 'Commands and live data exchanged with the systems already used in the production.'
  }
];

const supportingPoints = [
  'Windows-native product direction',
  'Dedicated separation between operator workflow and playback work',
  'Hardware-accelerated media and graphics paths',
  'Support for Windows production technologies such as NDI and Spout',
  'Visible timing, output and engine health'
];

const reliabilityThemes = [
  'Resource and cue validation',
  'Missing-target and missing-resource warnings',
  'Connection and input status',
  'Output, audio and engine telemetry',
  'Autosave and project recovery',
  'Logs that help explain what happened',
  'Safe editing and deliberate destructive actions'
];

const useCases = [
  {
    title: 'Theatre',
    copy: 'Run video, sound, graphics and control cues from a sequence that remains clear through rehearsals, changes and performance.'
  },
  {
    title: 'Concerts and touring',
    copy: 'Coordinate playback, visuals, outputs and external systems in a workflow designed for repeatable live operation.'
  },
  {
    title: 'Immersive installations',
    copy: 'Connect scheduled events, live inputs, sensors and realtime visual systems without reducing the installation to a fixed playlist.'
  },
  {
    title: 'Events and experiences',
    copy: 'Build dependable sequences for launches, conferences, exhibitions and branded experiences where multiple systems must act together.'
  },
  {
    title: 'Studios and creative technology',
    copy: 'Prototype and operate workflows that move between recorded media, realtime rendering and network control.'
  }
];

const integrations = [
  {
    name: 'Video and audio playback',
    status: 'Core',
    color: 'var(--sm-ready)'
  },
  { name: 'Images and text', status: 'Core', color: 'var(--sm-ready)' },
  { name: 'OSC and MIDI', status: 'Available', color: 'var(--sm-ready)' },
  {
    name: 'NDI and Spout',
    status: 'Available on Windows',
    color: 'var(--sm-ready)'
  },
  { name: 'DMX and timecode', status: 'Planned', color: 'var(--sm-warning)' },
  { name: 'Notch Blocks', status: 'Planned', color: 'var(--sm-warning)' },
  {
    name: 'Unreal Engine',
    status: 'Exploratory',
    color: 'var(--sm-text-faint)'
  },
  {
    name: 'TouchDesigner',
    status: 'Exploratory',
    color: 'var(--sm-text-faint)'
  },
  {
    name: 'HTTP, scripts & plugins',
    status: 'Planned',
    color: 'var(--sm-warning)'
  }
];

const whySummary = [
  'Cue-first enough to learn quickly',
  'Extensible enough for complex automation',
  'Windows-first for modern production environments',
  'Designed around live operator confidence',
  'Built to connect media and realtime systems',
  'Honest about system state and development state'
];

const accessFields = [
  { id: 'name', label: 'Name', span: false, type: 'input' },
  { id: 'email', label: 'Work email', span: false, type: 'input' },
  {
    id: 'company',
    label: 'Company or organisation',
    span: false,
    type: 'input'
  },
  { id: 'role', label: 'Role', span: false, type: 'input' },
  { id: 'prod', label: 'Type of productions', span: true, type: 'input' },
  {
    id: 'systems',
    label: 'Systems and protocols you use',
    span: true,
    type: 'input'
  },
  {
    id: 'problem',
    label: 'The biggest problem in your current workflow',
    span: true,
    type: 'textarea'
  }
];

const faqs = [
  {
    q: 'What is Showmesh?',
    a: 'Showmesh is a Windows-native realtime show automation workspace in development. It is designed to bring media playback, realtime graphics, control signals and external systems into one cue-based operating model.'
  },
  {
    q: 'Who is Showmesh for?',
    a: 'Showmesh is intended for show operators, technical directors, designers, programmers, venues and production teams working across theatre, concerts, installations, events and other live experiences.'
  },
  {
    q: 'Is Showmesh available now?',
    a: 'Showmesh is currently in active development. You can request early access and tell us about the workflows you would like the product to support.'
  },
  {
    q: 'Is Showmesh only for Windows?',
    a: 'The current product direction is Windows-first. This allows Showmesh to focus on native Windows media, graphics, audio and output workflows, including technologies commonly used in Windows-based production systems.'
  },
  {
    q: 'What can Showmesh control?',
    a: 'Current builds run video, audio, image and text cues with fades and actions, drive fullscreen, windowed, NDI and Spout outputs, and respond to OSC and MIDI. Further capabilities and integrations are labelled clearly according to their development state.'
  },
  {
    q: 'How does the cue model work?',
    a: 'Showmesh separates resources, actions and triggers. A resource defines what can be controlled, an action defines what changes and a trigger defines when it happens. Native media playback remains part of the cue lifecycle.'
  },
  {
    q: 'Does Showmesh support OSC and MIDI?',
    a: 'Yes. OSC input and output and MIDI Note and CC triggers already work in the current builds. The default OSC input port is 8000, and a MIDI Learn UI is still in development.'
  },
  {
    q: 'Does Showmesh support NDI and Spout?',
    a: 'Yes. NDI and Spout output both work on Windows in the current builds, alongside fullscreen and windowed output.'
  },
  {
    q: 'Can I suggest an integration or workflow?',
    a: 'Yes. Early product conversations are specifically intended to identify the combinations of media, control and realtime systems that matter most in real productions.'
  }
];

const fmt = (sec: number) => {
  const s = Math.max(0, sec);
  const m = Math.floor(s / 60);
  const r = Math.floor(s % 60);
  return `${m}:${String(r).padStart(2, '0')}`;
};

// Initial demo state (matches the client controller: index 1, progress 20%).
const startIndex = 1;
const startProgress = 20;
const startNext = (startIndex + 1) % cues.length;
const startCur = cues[startIndex];
const startNextCue = cues[startNext];
const cueData = JSON.stringify(
  cues.map((c) => ({ num: c.num, name: c.name, dur: c.dur }))
);
---

<BaseLayout
  title="Showmesh — Run media, realtime systems and control from one show sequence."
  description="Showmesh is a Windows-native show automation workspace. Bring playback, realtime graphics, control signals and external systems into one cue-based workflow."
>
  <SiteNav />
  <main id="main-content" data-cues={cueData}>
    <!-- HERO -->
    <section class="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="hero__copy">
        <img
          class="hero__logo"
          src="/showmesh-logo-mark-animated.svg"
          alt=""
          aria-hidden="true"
          width="120"
          height="99"
        />
        <div class="eyebrow eyebrow--ready">
          Realtime show automation for Windows
        </div>
        <h1>Run media, realtime systems and control from one show sequence.</h1>
        <p>
          Showmesh is a Windows-native show automation workspace for building
          and operating live shows. Bring playback, realtime graphics, control
          signals and external systems into one cue-based workflow—then see
          exactly what is live, what comes next and what the system is doing.
        </p>
        <div class="hero__actions">
          <a class="btn-solid" href="#access">Request early access</a>
          <a class="btn-outline" href="#model">Explore how it works</a>
        </div>
        <div class="hero__note">
          Showmesh is in active development. Early access is for operators,
          designers and technical teams who want to help shape the product.
        </div>
      </div>

      <!-- transport strip -->
      <div class="transport" data-transport>
        <div class="transport__now">
          <div class="transport__now-head">
            <span class="dot dot--playing" aria-hidden="true"></span>
            <span class="mono transport__cur-num" data-cur-num
              >{startCur.num}</span
            >
            <span class="transport__cur-name" data-cur-name
              >{startCur.name}</span
            >
            <span class="transport__time">
              <span class="mono" data-cur-elapsed
                >{fmt((startProgress / 100) * startCur.dur)}</span
              >
              <span class="mono transport__dur" data-cur-dur
                >/ {fmt(startCur.dur)}</span
              >
            </span>
          </div>
          <div class="transport__bar">
            <i data-cur-bar style={`width:${startProgress}%`}></i>
          </div>
        </div>
        <div class="transport__next">
          <span class="transport__next-label">Next</span>
          <span class="mono transport__next-num" data-next-num
            >{startNextCue.num}</span
          >
          <span class="transport__next-name" data-next-name
            >{startNextCue.name}</span
          >
        </div>
        <div class="transport__controls">
          <button type="button" class="go-btn" data-go>
            <span class="mono">GO</span>
          </button>
          <button type="button" class="panic-btn" data-panic>
            <b class="mono">PANIC</b>
          </button>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="band reveal">
      <div class="wrap grid-2 grid-2--top">
        <div>
          <div class="eyebrow eyebrow--playing">
            One show. Too many disconnected tools.
          </div>
          <h2>
            Your show already works as one system. Your software should too.
          </h2>
          <p class="lead">
            Live productions rarely depend on a single type of content. A cue
            may start a video, change a realtime visual, send control data,
            route an output and prepare the next state—all while the operator
            watches timing, connections and system health.
          </p>
          <p class="lead">
            When those tasks are spread across separate applications, the
            operator becomes the integration layer. Showmesh is being built to
            bring that work into one readable sequence.
          </p>
        </div>
        <ul class="checklist">
          {
            keyOutcomes.map((k) => (
              <li>
                <>
                  <span class="check" aria-hidden="true">
                    ✓
                  </span>
                  <span>{k}</span>
                </>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- VALUE -->
    <section class="band band--tight reveal">
      <div class="wrap center">
        <div class="eyebrow eyebrow--live">Connect. Automate. Run.</div>
        <h2 class="h2-center">
          One workspace for everything that makes the show.
        </h2>
        <div class="cards cards--3">
          {
            valueCards.map((c) => (
              <article class="card">
                <div
                  class="card__icon"
                  style={`background:${c.tint};color:${c.color}`}
                >
                  {c.icon}
                </div>
                <h3>{c.title}</h3>
                <p>{c.copy}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- MODEL -->
    <section id="model" class="band band--panel reveal">
      <div class="wrap center">
        <div class="eyebrow eyebrow--ready">Resource → Action → Trigger</div>
        <h2 class="h2-center">
          Build what should happen, not another workaround.
        </h2>
        <p class="lead lead--center">
          Showmesh is based on a simple automation model that can scale across
          different types of show technology.
        </p>
        <div class="model">
          {
            model.map((m, i) => (
              <>
                {i > 0 && (
                  <div class="model__arrow" aria-hidden="true">
                    →
                  </div>
                )}
                <article class="card model__card">
                  <div class="model__label" style={`color:${m.color}`}>
                    {m.label}
                  </div>
                  <h3>{m.title}</h3>
                  <p>{m.copy}</p>
                </article>
              </>
            ))
          }
        </div>
        <p class="lead lead--center note">
          The same model can describe a simple playback cue or a coordinated
          sequence across media, graphics and external systems. Your show
          remains readable even as the automation becomes more capable.
        </p>
      </div>
    </section>

    <!-- OPERATOR -->
    <section id="operator" class="band reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--playing">
            Built for the person pressing GO
          </div>
          <h2 class="h2-center">Know what is live. Know what is next.</h2>
          <p class="lead lead--center">
            During a live show, clarity is not a convenience. It is part of the
            system. Showmesh keeps the run order at the centre while timing, cue
            actions, live inputs, warnings and output state remain in context.
          </p>
        </div>

        <div class="cuelist" data-cuelist>
          <div class="cuelist__head">
            <span>Cue list</span>
            <span class="cuelist__hint"
              >click a cue, or press GO · live demo</span
            >
          </div>
          <div class="cuelist__rows">
            {
              cues.map((c, i) => (
                <button
                  type="button"
                  class:list={[
                    'cuerow',
                    {
                      'is-playing': i === startIndex,
                      'is-next': i === startNext
                    }
                  ]}
                  data-cue-index={i}
                  aria-label={`Jump to cue ${c.num}, ${c.name}`}
                >
                  <span class="cuerow__rail" aria-hidden="true" />
                  <span class="cuerow__num mono">{c.num}</span>
                  <span class="cuerow__icon" aria-hidden="true">
                    {c.icon}
                  </span>
                  <span class="cuerow__body">
                    <span class="cuerow__name">{c.name}</span>
                    <span
                      class="cuerow__progress"
                      data-progress
                      hidden={i !== startIndex}
                    >
                      <span class="cuerow__track">
                        <i
                          data-progress-bar
                          style={
                            i === startIndex
                              ? `width:${startProgress}%`
                              : 'width:0%'
                          }
                        />
                      </span>
                      <span class="mono cuerow__time" data-progress-time />
                    </span>
                    <span
                      class="cuerow__sub"
                      data-sub
                      hidden={i === startIndex}
                    >
                      {c.sub}
                    </span>
                  </span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="benefits">
          {
            benefits.map((b) => (
              <div class="benefits__item">
                <>
                  <span class="check" aria-hidden="true">
                    ✓
                  </span>
                  <span>{b}</span>
                </>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- LIVE OPERATOR CONCEPT -->
    <section id="workspace" class="band reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--live">The live operator concept</div>
          <h2 class="h2-center">Step into the actual Showmesh workspace.</h2>
          <p class="lead lead--center">
            An interactive concept of the operator interface—cue list,
            transport, live state and the GO button in one workspace. Click
            around below, or open it full screen.
          </p>
        </div>

        <figure class="appwindow" data-ui-window>
          <figcaption class="appwindow__bar">
            <span class="appwindow__dots" aria-hidden="true"
              ><i></i><i></i><i></i></span
            >
            <span class="appwindow__title">Showmesh — Operator</span>
            <a
              class="appwindow__open"
              href="/showmesh-ui.html"
              target="_blank"
              rel="noopener">Open full screen ↗</a
            >
          </figcaption>
          <div class="appwindow__viewport" data-ui-viewport>
            <a
              class="appwindow__shotlink"
              href="/showmesh-ui.html"
              target="_blank"
              rel="noopener"
              data-ui-shot
            >
              <img
                class="appwindow__shot"
                src="/showmesh-application.png"
                alt="Showmesh operator interface: cue list, transport strip with NOW / NEXT and GO, and live system state"
                loading="lazy"
                width="1280"
                height="800"
              />
              <span class="appwindow__launch"
                >Open the interactive concept ↗</span
              >
            </a>
            <iframe
              class="appwindow__frame"
              title="Showmesh operator interface — interactive concept"
              data-ui-frame
              loading="lazy"
              width="1280"
              height="800"></iframe>
          </div>
        </figure>
        <p class="fine uifeature__note">
          Interactive concept for illustration. Not the final product build.
        </p>
      </div>
    </section>

    <!-- LIVE SYSTEMS -->
    <section class="band band--panel reveal">
      <div class="wrap grid-2 grid-2--center">
        <div>
          <div class="eyebrow eyebrow--live">
            Control that responds in realtime
          </div>
          <h2>Let live data become part of the cue.</h2>
          <p class="lead">
            A show does not always follow a fixed timeline. A performer moves, a
            sensor changes, timecode advances or another system sends a command.
          </p>
          <p class="lead">
            Showmesh lets OSC, MIDI and realtime parameters participate in the
            same cue workflow as media playback, with timecode support planned.
            Operators can see where data comes from, what it controls and
            whether it is live.
          </p>
          <p class="lead lead--accent">
            From a simple GO command to a parameter continuously driven by live
            input, the relationship remains visible inside the show sequence.
          </p>
        </div>
        <div class="signals">
          {
            liveSignals.map((s) => (
              <div class="signals__row">
                <span
                  class="dot dot--live"
                  style={`animation-duration:${s.pulse}`}
                  aria-hidden="true"
                />
                <span class="signals__label">{s.label}</span>
                <span class="mono signals__status">{s.status}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- MEDIA -->
    <section class="band reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--warning">More than a playlist</div>
          <h2 class="h2-center">
            Move from playback to realtime without changing the operating model.
          </h2>
          <p class="lead lead--center">
            Shows increasingly combine conventional media with generative
            graphics, interactive visuals and GPU-driven effects. Showmesh is
            being designed so those systems can live beside video, audio, images
            and control cues without becoming a separate workflow for the
            operator.
          </p>
        </div>
        <div class="cards cards--4">
          {
            capabilityGroups.map((g) => (
              <article class="card card--sm">
                <h3>{g.title}</h3>
                <p>{g.copy}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- WINDOWS -->
    <section class="band band--panel reveal">
      <div class="wrap grid-2 grid-2--center">
        <div>
          <div class="eyebrow eyebrow--ready">
            Designed for Windows production systems
          </div>
          <h2>Built around the machines already running the room.</h2>
          <p class="lead">
            Windows is central to many media-server, realtime graphics and
            live-production workflows. Showmesh is being built for that
            environment from the beginning—not treated as a secondary platform.
          </p>
          <p class="lead">
            The product direction combines a focused operator interface with
            native playback, rendering, audio and output paths. The goal is a
            system that remains responsive to edit and dependable when the show
            is running.
          </p>
        </div>
        <ul class="checklist">
          {
            supportingPoints.map((s) => (
              <li>
                <>
                  <span class="check" aria-hidden="true">
                    ✓
                  </span>
                  <span>{s}</span>
                </>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- RELIABILITY -->
    <section class="band reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--warning">Confidence is a feature</div>
          <h2 class="h2-center">
            The operator should not have to guess whether the system is ready.
          </h2>
          <p class="lead lead--center">
            A show-control system must communicate more than success or failure.
            It should show what is connected, what is missing, what is running
            and what needs attention before it becomes a live problem.
          </p>
        </div>
        <div class="themes">
          {
            reliabilityThemes.map((r) => (
              <div class="themes__item">
                <>
                  <span class="diamond" aria-hidden="true">
                    ◆
                  </span>
                  <span>{r}</span>
                </>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- USE CASES -->
    <section class="band band--panel reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--live">
            Different rooms. One operating model.
          </div>
          <h2 class="h2-center">
            Made for shows that combine media, timing and control.
          </h2>
        </div>
        <div class="cards cards--auto">
          {
            useCases.map((u) => (
              <article class="card card--sm">
                <h3>{u.title}</h3>
                <p>{u.copy}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- INTEGRATIONS -->
    <section id="integrations" class="band reveal">
      <div class="wrap">
        <div class="center intro">
          <div class="eyebrow eyebrow--ready">
            Work with the systems around you
          </div>
          <h2 class="h2-center">Connect by role, not by logo count.</h2>
          <p class="lead lead--center">
