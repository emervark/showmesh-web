<script>
  // ---- Scroll reveal ----
  // Content is visible by default; only arm the hidden-then-animate behaviour
  // when JS + motion are available, so a script error never blanks the page.
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (!reduceMotion && reveals.length) {
    document.documentElement.classList.add('js-reveal');
    // Reveal anything currently at or above the fold, then animate the rest in
    // as they are scrolled to. A scroll sweep self-heals sections that an
    // in-page anchor jump skipped over without ever intersecting.
    const sweep = () => {
      const limit = window.innerHeight * 0.88;
      for (const el of reveals) {
        if (
          !el.classList.contains('is-visible') &&
          el.getBoundingClientRect().top < limit
        ) {
          el.classList.add('is-visible');
        }
      }
    };
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        sweep();
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    window.addEventListener('hashchange', onScroll);
    sweep();
  }

  // ---- Shared cue demo (hero transport + operator cue list) ----
  const main = document.getElementById('main-content');
  type Cue = { num: string; name: string; dur: number };
  let cues: Cue[] = [];
  try {
    cues = JSON.parse(main?.dataset.cues || '[]');
  } catch {
    cues = [];
  }

  const fmt = (sec: number) => {
    const s = Math.max(0, sec);
    const m = Math.floor(s / 60);
    const r = Math.floor(s % 60);
    return `${m}:${String(r).padStart(2, '0')}`;
  };

  const rows = Array.from(document.querySelectorAll<HTMLElement>('.cuerow'));

  const t = {
    curNum: document.querySelector<HTMLElement>('[data-cur-num]'),
    curName: document.querySelector<HTMLElement>('[data-cur-name]'),
    curElapsed: document.querySelector<HTMLElement>('[data-cur-elapsed]'),
    curDur: document.querySelector<HTMLElement>('[data-cur-dur]'),
    curBar: document.querySelector<HTMLElement>('[data-cur-bar]'),
    nextNum: document.querySelector<HTMLElement>('[data-next-num]'),
    nextName: document.querySelector<HTMLElement>('[data-next-name]')
  };

  if (cues.length) {
    let index = 1;
    let progress = 20;
    let paused = false;
    let panicReset = 0;

    const render = () => {
      const len = cues.length;
      const nextIdx = (index + 1) % len;
      const cur = cues[index];
      const nxt = cues[nextIdx];

      // transport
      if (t.curNum) t.curNum.textContent = cur.num;
      if (t.curName) t.curName.textContent = cur.name;
      if (t.curElapsed)
        t.curElapsed.textContent = fmt((progress / 100) * cur.dur);
      if (t.curDur) t.curDur.textContent = `/ ${fmt(cur.dur)}`;
      if (t.curBar) t.curBar.style.width = `${progress}%`;
      if (t.nextNum) t.nextNum.textContent = nxt.num;
      if (t.nextName) t.nextName.textContent = nxt.name;

      // cue rows
      rows.forEach((row, i) => {
        const playing = i === index;
        const isNext = i === nextIdx;
        row.classList.toggle('is-playing', playing);
        row.classList.toggle('is-next', isNext);
        const progEl = row.querySelector<HTMLElement>('[data-progress]');
        const subEl = row.querySelector<HTMLElement>('[data-sub]');
        const bar = row.querySelector<HTMLElement>('[data-progress-bar]');
        const time = row.querySelector<HTMLElement>('[data-progress-time]');
        if (progEl) progEl.hidden = !playing;
        if (subEl) subEl.hidden = playing;
        if (playing) {
          const dur = cues[i].dur;
          if (bar) bar.style.width = `${progress}%`;
          if (time)
            time.textContent = `${fmt((progress / 100) * dur)} / ${fmt(dur)}`;
        } else if (bar) {
          bar.style.width = '0%';
        }
      });
    };

    const advance = () => {
      index = (index + 1) % cues.length;
      progress = 0;
      render();
    };

    rows.forEach((row) => {
      row.addEventListener('click', () => {
        const i = Number(row.dataset.cueIndex);
        if (!Number.isNaN(i)) {
          index = i;
          progress = 0;
          render();
        }
      });
    });

    document.querySelector('[data-go]')?.addEventListener('click', advance);
    document.querySelector('[data-panic]')?.addEventListener('click', () => {
      paused = true;
      progress = 0;
      render();
      window.clearTimeout(panicReset);
      panicReset = window.setTimeout(() => {
        paused = false;
      }, 1100);
    });

    window.setInterval(() => {
      if (paused) return;
      progress += 1.6;
      if (progress >= 100) {
        advance();
      } else {
        render();
      }
    }, 140);

    render();
  }

  // ---- FAQ accordion ----
  document
    .querySelectorAll<HTMLElement>('[data-faq] .faq__item')
    .forEach((item) => {
      const btn = item.querySelector<HTMLButtonElement>('[data-faq-toggle]');
      const panel = item.querySelector<HTMLElement>('[data-faq-panel]');
      const icon = item.querySelector<HTMLElement>('.faq__icon');
      btn?.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        if (panel) panel.hidden = open;
        if (icon) icon.textContent = open ? '+' : '−';
      });
    });

  // ---- Early access form ----
  const form = document.querySelector<HTMLFormElement>('[data-access-form]');
  const done = document.querySelector<HTMLElement>('[data-access-done]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.hidden = true;
    if (done) done.hidden = false;
  });

  // ---- Live operator concept: scale + lazy-load the embedded workspace ----
  // On wide screens, once the window scrolls into view, load the interactive
  // UI and scale the fixed 1280x800 iframe to fit its container. Narrow screens
  // keep the static screenshot (which links to the full-screen concept) and
  // never fetch the heavy embed.
  const BASE_W = 1280;
  const uiWindow = document.querySelector<HTMLElement>('[data-ui-window]');
  const uiFrame = document.querySelector<HTMLIFrameElement>('[data-ui-frame]');
  const uiViewport = document.querySelector<HTMLElement>('[data-ui-viewport]');
  const MIN_LIVE_WIDTH = 900;

  if (uiWindow && uiFrame && uiViewport) {
    let loaded = false;

    const fitFrame = () => {
      const scale = uiViewport.clientWidth / BASE_W;
      uiFrame.style.transform = `scale(${scale})`;
    };

    const goLive = () => {
      if (loaded || window.innerWidth < MIN_LIVE_WIDTH) return;
      loaded = true;
      fitFrame();
      uiFrame.src = '/showmesh-ui.html';
      uiFrame.addEventListener(
        'load',
        () => uiWindow.classList.add('is-live'),
        {
          once: true
        }
      );
    };

    if ('IntersectionObserver' in window) {
      const uiIo = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            goLive();
            uiIo.disconnect();
          }
        },
        { rootMargin: '200px' }
      );
      uiIo.observe(uiWindow);
    } else {
      goLive();
    }

    window.addEventListener('resize', () => {
      if (loaded) fitFrame();
    });
  }
</script>

